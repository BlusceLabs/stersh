# ── Watchfy production deployment — copy to .env and fill in ────────────────

# TMDB API key (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# ── Service ports (host-side) ───────────────────────────────────────────────
FRONTEND_PORT=4321
GATEWAY_PORT=8080

# ── CORS / Security ─────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the backend.
# Include the frontend URL (http://localhost:4321 in dev, https://your.domain
# in prod) and the gateway URL.
ALLOWED_ORIGINS=http://localhost:4321,http://localhost:8080

# HSTS is sent only when the connection is HTTPS. Disable locally if you
# serve over plain HTTP during development.
SECURITY_HSTS_ENABLED=true
