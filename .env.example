# Stersh environment configuration
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Required: TMDB API key (get one at https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# Optional: comma-separated allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:4321,http://localhost:8080

# Optional: Redis URL for distributed caching (defaults to in-memory)
# REDIS_URL=redis://localhost:6379

# Optional: JWT secret (auto-generated if not set, but required in production)
JWT_SECRET=change_me_in_production_min_32_chars_long

# Optional: log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: HSTS (disable for local dev)
SECURITY_HSTS_ENABLED=true

# Optional: FFmpeg binary path
# FFMPEG_BIN=ffmpeg

# Optional: service ports
FRONTEND_PORT=4321
GATEWAY_PORT=8080
