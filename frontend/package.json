{
  "name": "watchfy",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "node ./dist/server/entry.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "check": "svelte-check --tsconfig ./tsconfig.svelte-check.json",
    "check:summary": "svelte-check --tsconfig ./tsconfig.svelte-check.json --output human --threshold warning",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@astrojs/node": "^8.3.1",
    "@astrojs/svelte": "^6.0.0",
    "@astrojs/tailwind": "^6.0.1",
    "@watchfy/animations": "file:./packages/animations",
    "@watchfy/design-tokens": "file:./packages/design-tokens",
    "@watchfy/shared-types": "file:./packages/shared-types",
    "@watchfy/ui-primitives": "file:./packages/ui-primitives",
    "astro": "^4.16.18",
    "framer-motion": "^11.15.0",
    "hls.js": "^1.6.16",
    "svelte": "^5.2.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "svelte-check": "^4.5.0",
    "vite": "^5.4.21"
  }
}
