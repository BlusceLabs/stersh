---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-black text-white min-h-screen antialiased">
    <nav class="fixed top-0 left-0 right-0 z-50 bg-black/80 backdrop-blur-sm border-b border-zinc-800">
      <div class="container mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="text-2xl font-bold text-yellow-500">Watchfy</a>
        
        <div class="flex items-center gap-4">
          <a href="/movies" class="text-gray-300 hover:text-white transition">Movies</a>
          <a href="/tv" class="text-gray-300 hover:text-white transition">TV Shows</a>
        </div>
      </div>
    </nav>
    
    <div class="pt-20">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;
</style>