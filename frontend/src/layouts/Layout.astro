---
import Navbar from '../components/Navbar.svelte';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth bg-[#09090b]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Watchfy</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>

  <body class="bg-[#09090b] text-zinc-100 min-h-screen antialiased selection:bg-red-500/30 selection:text-white overflow-x-hidden">

    <Navbar client:load />

    <div class="min-h-screen relative w-full">
      <slot />
    </div>

    <script type="text/javascript" src="https://cdnjs.buymeacoffee.com/1.0.0/button.prod.min.js" data-name="bmc-button" data-slug="midknightmantra" data-color="#FFDD00" data-emoji="" data-font="Bree" data-text="" data-outline-color="#000000" data-font-color="#000000" data-coffee-color="#ffffff"></script>
  </body>
</html>