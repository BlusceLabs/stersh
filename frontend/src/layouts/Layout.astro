---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-surface-sunken text-text min-h-screen antialiased">
    <nav class="fixed top-0 left-0 right-0 z-50 bg-surface-sunken/80 backdrop-blur-sm border-b border-border">
      <div class="container mx-auto px-4 py-3 flex items-center justify-between">
        <div class="flex items-center gap-6">
          <a href="/" class="text-2xl font-bold text-primary">Watchfy</a>
          <div class="hidden md:flex items-center gap-4">
            <a href="/home" class="text-text-muted hover:text-text transition">Home</a>
            <a href="/movies" class="text-text-muted hover:text-text transition">Movies</a>
            <a href="/tv" class="text-text-muted hover:text-text transition">TV Shows</a>
            <a href="/search" class="text-text-muted hover:text-text transition">Search</a>
          </div>
        </div>
      </div>
    </nav>
    
    <div class="pt-20">
      <slot />
    </div>
  </body>
</html>

