---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Your account | Watchfy">
  <main class="min-h-screen bg-base">
    <div class="max-w-4xl mx-auto px-4 md:px-6 py-6">
      <h1 class="text-2xl font-bold text-ink mb-6">Your account</h1>

      <section class="border-t border-white/10 py-6">
        <h2 class="text-base font-medium text-ink mb-1">Profile</h2>
        <div class="flex items-start gap-6 mt-4">
          <div class="w-24 h-24 rounded-full bg-base-2 flex items-center justify-center text-2xl font-medium text-ink" id="avatar">?</div>
          <div class="flex-1 min-w-0 space-y-3">
            <div>
              <h3 class="text-base text-ink" id="display-username">Guest</h3>
              <p class="text-sm text-ink-muted" id="display-email">Not signed in</p>
            </div>
            <div class="flex flex-wrap gap-2 text-sm">
              <span class="px-3 py-1 bg-base-2 text-ink-secondary rounded-full"><span id="stat-favorites">0</span> favorites</span>
              <span class="px-3 py-1 bg-base-2 text-ink-secondary rounded-full"><span id="stat-watchlist">0</span> watchlist</span>
              <span class="px-3 py-1 bg-base-2 text-ink-secondary rounded-full"><span id="stat-history">0</span> watched</span>
            </div>
          </div>
        </div>
      </section>

      <section class="border-t border-white/10 py-6">
        <h2 class="text-base font-medium text-ink mb-4">Edit profile</h2>
        <form id="profile-form" class="space-y-4 max-w-md">
          <div>
            <label for="username" class="block text-sm text-ink-secondary mb-1">Username</label>
            <input type="text" id="username" name="username" class="w-full bg-base-2 border border-white/10 text-ink rounded-md px-3 py-2 text-sm focus:outline-none focus:border-yt-blue" placeholder="Username" />
          </div>
          <div>
            <label for="email" class="block text-sm text-ink-secondary mb-1">Email</label>
            <input type="email" id="email" name="email" class="w-full bg-base-2 border border-white/10 text-ink rounded-md px-3 py-2 text-sm focus:outline-none focus:border-yt-blue" placeholder="Email" />
          </div>
          <div id="profile-message" class="hidden text-sm"></div>
          <div class="flex gap-2">
            <button type="submit" class="h-9 px-5 border border-yt-blue text-yt-blue rounded-full text-sm font-medium hover:bg-yt-blue/10">Save</button>
            <button type="button" onclick={() => { (document.getElementById('username') as HTMLInputElement).value=''; (document.getElementById('email') as HTMLInputElement).value=''; }} class="h-9 px-5 text-ink-secondary rounded-full text-sm font-medium hover:bg-base-2">Cancel</button>
          </div>
        </form>
      </section>

      <section class="border-t border-white/10 py-6">
        <h2 class="text-base font-medium text-ink mb-4">Playback preferences</h2>
        <div class="space-y-5 max-w-md">
          <div>
            <label class="block text-sm text-ink-secondary mb-2">Default playback speed</label>
            <div class="flex flex-wrap gap-2" id="speed-options">
              {[0.5, 0.75, 1, 1.25, 1.5, 2].map((speed) => (
                <button type="button" data-speed={speed} class="speed-btn h-9 px-3 bg-base-2 text-ink-secondary rounded-full text-sm font-medium hover:bg-base-3">
                  {speed}x
                </button>
              ))}
            </div>
          </div>
          <div>
            <label class="block text-sm text-ink-secondary mb-2">Default volume</label>
            <input type="range" id="volume-pref" min="0" max="100" class="w-full h-1 bg-base-3 rounded-full appearance-none cursor-pointer accent-white" />
            <div class="flex justify-between text-xs text-ink-muted mt-1">
              <span>0%</span>
              <span id="volume-display">100%</span>
              <span>100%</span>
            </div>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-ink-secondary">Start videos muted</span>
            <button type="button" id="muted-pref" class="relative w-10 h-6 rounded-full bg-base-3 transition-colors duration-200">
              <div class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-white transition-transform duration-200" id="muted-toggle"></div>
            </button>
          </div>
          <div id="prefs-message" class="hidden text-sm"></div>
          <button type="button" id="save-prefs" class="h-9 px-5 border border-yt-blue text-yt-blue rounded-full text-sm font-medium hover:bg-yt-blue/10">Save preferences</button>
        </div>
      </section>

      <div id="auth-required" class="hidden py-20 text-center">
        <div class="w-16 h-16 rounded-full bg-base-2 mx-auto mb-4 flex items-center justify-center text-ink-muted">
          <svg viewBox="0 0 24 24" class="w-7 h-7" fill="currentColor" aria-hidden="true">
            <path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm0 2c-3.3 0-8 1.7-8 5v1h16v-1c0-3.3-4.7-5-8-5z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-ink mb-2">Sign in required</h3>
        <p class="text-sm text-ink-muted mb-6">Sign in to view and edit your profile.</p>
        <a href="/signin" class="inline-flex items-center gap-2 h-9 px-5 border border-yt-blue text-yt-blue rounded-full text-sm font-medium hover:bg-yt-blue/10">Sign in</a>
      </div>
    </div>
  </main>
</Layout>

<script>
  function getAuthToken(): string | null {
    return localStorage.getItem('watchfy_token') || localStorage.getItem('access_token');
  }

  function showMessage(id: string, text: string, ok: boolean) {
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent = text;
    el.className = `text-sm ${ok ? 'text-green-400' : 'text-yt-red'}`;
    el.classList.remove('hidden');
    setTimeout(() => el.classList.add('hidden'), 3000);
  }

  async function loadProfile() {
    const token = getAuthToken();
    const authRequired = document.getElementById('auth-required');
    if (!token) {
      authRequired?.classList.remove('hidden');
      return;
    }

    try {
      const response = await fetch('/api/auth/me', { headers: { 'Authorization': `Bearer ${token}` } });
      if (!response.ok) throw new Error('Failed to load profile');
      const user = await response.json();

      const avatar = document.getElementById('avatar');
      const displayUsername = document.getElementById('display-username');
      const displayEmail = document.getElementById('display-email');
      const usernameInput = document.getElementById('username') as HTMLInputElement;
      const emailInput = document.getElementById('email') as HTMLInputElement;

      if (avatar) avatar.textContent = (user.username || '?')[0].toUpperCase();
      if (displayUsername) displayUsername.textContent = user.username || 'User';
      if (displayEmail) displayEmail.textContent = user.email || '';
      if (usernameInput) usernameInput.value = user.username || '';
      if (emailInput) emailInput.value = user.email || '';

      loadStats(token);
    } catch (e) {
      console.error('Profile load error:', e);
    }
  }

  async function loadStats(token: string) {
    try {
      const [favRes, wlRes, histRes] = await Promise.all([
        fetch('/user/favorites', { headers: { 'Authorization': `Bearer ${token}` } }),
        fetch('/user/watchlist', { headers: { 'Authorization': `Bearer ${token}` } }),
        fetch('/user/history', { headers: { 'Authorization': `Bearer ${token}` } }),
      ]);
      const favData = favRes.ok ? await favRes.json() : { total: 0 };
      const wlData = wlRes.ok ? await wlRes.json() : { total: 0 };
      const histData = histRes.ok ? await histRes.json() : { total: 0 };
      const sf = document.getElementById('stat-favorites');
      const sw = document.getElementById('stat-watchlist');
      const sh = document.getElementById('stat-history');
      if (sf) sf.textContent = String(favData.total || 0);
      if (sw) sw.textContent = String(wlData.total || 0);
      if (sh) sh.textContent = String(histData.total || 0);
    } catch {}
  }

  function setupProfileForm() {
    const form = document.getElementById('profile-form');
    if (!form) return;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const token = getAuthToken();
      if (!token) return;
      const usernameInput = document.getElementById('username') as HTMLInputElement;
      const emailInput = document.getElementById('email') as HTMLInputElement;
      try {
        const response = await fetch('/api/auth/me', {
          method: 'PATCH',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ username: usernameInput?.value, email: emailInput?.value }),
        });
        if (!response.ok) throw new Error('Failed to update');
        showMessage('profile-message', 'Profile updated', true);
        loadProfile();
      } catch {
        showMessage('profile-message', 'Failed to update profile', false);
      }
    });
  }

  let isMuted = false;

  function loadPlaybackPrefs() {
    const prefsStr = localStorage.getItem('watchfy_playback_prefs');
    const prefs = prefsStr ? JSON.parse(prefsStr) : {};
    const currentSpeed = prefs.playbackRate || 1;
    const speedBtns = document.querySelectorAll<HTMLElement>('.speed-btn');
    speedBtns.forEach(btn => {
      const speed = parseFloat(btn.getAttribute('data-speed') || '1');
      if (speed === currentSpeed) activateSpeed(btn);
      btn.addEventListener('click', () => {
        speedBtns.forEach(b => deactivateSpeed(b));
        activateSpeed(btn);
      });
    });

    function activateSpeed(b: HTMLElement) {
      b.classList.add('bg-white', 'text-base');
      b.classList.remove('bg-base-2', 'text-ink-secondary');
    }
    function deactivateSpeed(b: HTMLElement) {
      b.classList.remove('bg-white', 'text-base');
      b.classList.add('bg-base-2', 'text-ink-secondary');
    }

    const volumeSlider = document.getElementById('volume-pref') as HTMLInputElement;
    const volumeDisplay = document.getElementById('volume-display');
    if (volumeSlider) {
      const vol = prefs.volume !== undefined ? Math.round(prefs.volume * 100) : 100;
      volumeSlider.value = String(vol);
      if (volumeDisplay) volumeDisplay.textContent = `${vol}%`;
      volumeSlider.addEventListener('input', () => {
        if (volumeDisplay) volumeDisplay.textContent = `${volumeSlider.value}%`;
      });
    }

    const mutedPref = document.getElementById('muted-pref');
    const mutedToggle = document.getElementById('muted-toggle');
    isMuted = prefs.muted || false;

    function updateMutedUI() {
      if (!mutedPref || !mutedToggle) return;
      if (isMuted) {
        mutedPref.classList.add('bg-white');
        mutedPref.classList.remove('bg-base-3');
        (mutedToggle as HTMLElement).style.transform = 'translateX(16px)';
        (mutedToggle as HTMLElement).classList.add('bg-yt-red');
        (mutedToggle as HTMLElement).classList.remove('bg-white');
      } else {
        mutedPref.classList.remove('bg-white');
        mutedPref.classList.add('bg-base-3');
        (mutedToggle as HTMLElement).style.transform = 'translateX(0)';
        (mutedToggle as HTMLElement).classList.remove('bg-yt-red');
        (mutedToggle as HTMLElement).classList.add('bg-white');
      }
    }
    updateMutedUI();
    if (mutedPref) {
      mutedPref.addEventListener('click', () => { isMuted = !isMuted; updateMutedUI(); });
    }
  }

  function setupSavePrefs() {
    const saveBtn = document.getElementById('save-prefs');
    if (!saveBtn) return;
    saveBtn.addEventListener('click', () => {
      const speedBtns = document.querySelectorAll<HTMLElement>('.speed-btn');
      let selectedSpeed = 1;
      speedBtns.forEach(btn => {
        if (btn.classList.contains('bg-white')) {
          selectedSpeed = parseFloat(btn.getAttribute('data-speed') || '1');
        }
      });
      const volumeSlider = document.getElementById('volume-pref') as HTMLInputElement;
      const volume = volumeSlider ? parseInt(volumeSlider.value) / 100 : 1;
      localStorage.setItem('watchfy_playback_prefs', JSON.stringify({
        playbackRate: selectedSpeed,
        volume: volume,
        muted: isMuted,
      }));
      showMessage('prefs-message', 'Preferences saved', true);
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    loadProfile();
    setupProfileForm();
    loadPlaybackPrefs();
    setupSavePrefs();
  });
</script>
