---
import Layout from '../layouts/Layout.astro';
import FilterChips from '../components/FilterChips.svelte';
---

<Layout title="My List | Stersh">
  <main class="min-h-screen bg-base">
    <div class="px-4 md:px-6 pt-2">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="text-2xl font-bold text-ink">My List</h1>
        <span class="text-sm text-ink-muted"><span id="list-count">0</span> items</span>
      </div>

      <div id="filter-bar" class="mb-6">
        <FilterChips
          chips={[
            { id: 'all', label: 'All' },
            { id: 'movies', label: 'Movies' },
            { id: 'tv', label: 'TV Shows' },
          ]}
          active="all"
          hrefBuilder={(id) => '#'}
        />
      </div>

      <div id="list-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-6 opacity-0 transition-opacity duration-300"></div>

      <div id="grid-skeleton" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-6">
        {Array.from({ length: 8 }).map(() => (
          <div>
            <div class="skeleton aspect-video rounded-xl"></div>
            <div class="flex gap-3 mt-3">
              <div class="skeleton w-9 h-9 rounded-full flex-shrink-0"></div>
              <div class="flex-1 space-y-2">
                <div class="skeleton h-3.5 rounded w-5/6"></div>
                <div class="skeleton h-3 rounded w-3/4"></div>
                <div class="skeleton h-3 rounded w-1/2"></div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div id="empty-state" class="hidden py-20 text-center">
        <div class="w-16 h-16 rounded-full bg-base-2 mx-auto mb-4 flex items-center justify-center text-ink-muted">
          <svg viewBox="0 0 24 24" class="w-7 h-7" fill="currentColor" aria-hidden="true">
            <path d="M5 3h14a1 1 0 0 1 1 1v16l-8-4-8 4V4a1 1 0 0 1 1-1z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-ink mb-2">Your list is empty</h3>
        <p class="text-sm text-ink-muted mb-6">Save movies and TV shows to watch later.</p>
        <a href="/movies" class="inline-flex items-center gap-2 h-9 px-5 border border-yt-blue text-yt-blue rounded-full text-sm font-medium hover:bg-yt-blue/10">
          Browse movies
        </a>
      </div>

      <div id="auth-required" class="hidden py-20 text-center">
        <div class="w-16 h-16 rounded-full bg-base-2 mx-auto mb-4 flex items-center justify-center text-ink-muted">
          <svg viewBox="0 0 24 24" class="w-7 h-7" fill="currentColor" aria-hidden="true">
            <path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm0 2c-3.3 0-8 1.7-8 5v1h16v-1c0-3.3-4.7-5-8-5z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-ink mb-2">Sign in to view your list</h3>
        <p class="text-sm text-ink-muted mb-6">Save movies and TV shows to watch later across devices.</p>
        <a href="/signin" class="inline-flex items-center gap-2 h-9 px-5 border border-yt-blue text-yt-blue rounded-full text-sm font-medium hover:bg-yt-blue/10">
          Sign in
        </a>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { tmdbApi } from '../lib/api';
  import { createMediaCardElement } from '../lib/mediaCardFactory';
  import { getToken, authFetch } from '../lib/auth';

  type FilterType = 'all' | 'movies' | 'tv';
  let currentFilter: FilterType = 'all';
  let watchlistData: { movies: any[]; tv_shows: any[] } = { movies: [], tv_shows: [] };

  function getAuthToken(): string | null {
    return getToken();
  }

  function setActiveChip() {
    const idx = ['all', 'movies', 'tv'].indexOf(currentFilter);
    document.querySelectorAll('#filter-bar [data-active]').forEach((el, i) => {
      el.setAttribute('data-active', i === idx ? 'true' : 'false');
    });
  }

  function getAllItems() {
    const items: any[] = [];
    watchlistData.movies.forEach(m => items.push({ ...m, media_type: 'movie' }));
    watchlistData.tv_shows.forEach(t => items.push({ ...t, media_type: 'tv' }));
    return items;
  }

  function getFilteredItems() {
    const all = getAllItems();
    if (currentFilter === 'movies') return all.filter(i => i.media_type === 'movie');
    if (currentFilter === 'tv') return all.filter(i => i.media_type === 'tv');
    return all;
  }

  function renderGrid() {
    const grid = document.getElementById('list-grid');
    const skeleton = document.getElementById('grid-skeleton');
    const emptyState = document.getElementById('empty-state');
    const countEl = document.getElementById('list-count');

    if (!grid || !skeleton || !emptyState) return;

    skeleton.style.display = 'none';
    grid.classList.add('opacity-0');
    grid.replaceChildren();

    const items = getFilteredItems();
    if (countEl) countEl.textContent = String(items.length);

    if (items.length === 0) {
      grid.classList.add('hidden');
      emptyState.classList.remove('hidden');
      return;
    }

    emptyState.classList.add('hidden');
    grid.classList.remove('hidden');

    const fragment = document.createDocumentFragment();
    items.forEach((item: any) => {
      fragment.appendChild(createMediaCardElement(item));
    });
    grid.appendChild(fragment);

    requestAnimationFrame(() => grid.classList.remove('opacity-0'));
  }

  async function fetchWatchlist() {
    const token = getAuthToken();
    const authRequired = document.getElementById('auth-required');
    const skeleton = document.getElementById('grid-skeleton');

    if (!token) {
      if (skeleton) skeleton.style.display = 'none';
      if (authRequired) authRequired.classList.remove('hidden');
      return;
    }

    try {
      const response = await authFetch('/user/watchlist');
      if (!response.ok) throw new Error('Failed to fetch watchlist');
      const data = await response.json();
      watchlistData = { movies: data.movies || [], tv_shows: data.tv_shows || [] };

      const allItems = getAllItems();
      const enrichedItems = await Promise.all(
        allItems.map(async (item) => {
          try {
            const details = await tmdbApi.details(item.media_type, item.tmdb_id);
            return { ...item, ...details };
          } catch { return item; }
        })
      );
      watchlistData.movies = enrichedItems.filter(i => i.media_type === 'movie');
      watchlistData.tv_shows = enrichedItems.filter(i => i.media_type === 'tv');
      renderGrid();
    } catch (e) {
      console.error('Watchlist fetch error:', e);
      if (skeleton) skeleton.style.display = 'none';
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    fetchWatchlist();
    document.querySelectorAll('#filter-bar [data-active]').forEach((el, i) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        currentFilter = ['all', 'movies', 'tv'][i] as FilterType;
        setActiveChip();
        renderGrid();
      });
    });
  });
</script>
