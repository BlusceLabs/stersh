---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Search" description="Search movies and TV shows on Stersh.">
  <main class="min-h-screen bg-base">
    <div class="px-4 md:px-6 pt-2">
      <h1 class="text-2xl font-bold text-ink mb-4">Search</h1>

      <form id="search-form" class="mb-6 max-w-3xl">
        <div class="flex items-center gap-2">
          <div class="flex flex-1 h-12 border border-white/10 rounded-full bg-base-1 focus-within:border-yt-blue transition-colors overflow-hidden">
            <div class="flex items-center pl-5 text-ink-secondary">
              <svg viewBox="0 0 24 24" class="w-5 h-5" fill="currentColor" aria-hidden="true">
                <path d="M10 4a6 6 0 1 0 3.815 10.65L18 18.835 19.415 17.42l-4.185-4.185A6 6 0 0 0 10 4zm0 2a4 4 0 1 1 0 8 4 4 0 0 1 0-8z" />
              </svg>
            </div>
            <input
              id="search-input"
              type="text"
              name="q"
              autocomplete="off"
              placeholder="Search titles, actors, genres..."
              class="flex-1 bg-transparent border-0 outline-none text-ink text-base placeholder:text-ink-muted px-3"
            />
          </div>
        </div>
      </form>

      <div id="filter-bar" class="hidden flex flex-wrap items-center gap-2 mb-6">
        <div class="relative">
          <select id="type-filter" class="appearance-none bg-base-2 border border-white/10 text-ink text-sm pl-3 pr-9 py-2 rounded-full focus:outline-none focus:border-yt-blue cursor-pointer hover:bg-base-3">
            <option value="multi">All Types</option>
            <option value="movie">Movies</option>
            <option value="tv">TV Shows</option>
          </select>
          <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-ink-muted pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
        </div>
        <div class="relative">
          <select id="genre-filter" class="appearance-none bg-base-2 border border-white/10 text-ink text-sm pl-3 pr-9 py-2 rounded-full focus:outline-none focus:border-yt-blue cursor-pointer hover:bg-base-3">
            <option value="">All Genres</option>
          </select>
          <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-ink-muted pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
        </div>
        <input
          type="number"
          id="year-filter"
          placeholder="Year"
          min="1900"
          max="2030"
          class="w-28 bg-base-2 border border-white/10 text-ink text-sm px-3 py-2 rounded-full focus:outline-none focus:border-yt-blue placeholder:text-ink-muted"
        />
      </div>

      <div id="search-skeleton" class="hidden grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-6">
        {Array.from({ length: 8 }).map(() => (
          <div>
            <div class="skeleton aspect-video rounded-xl"></div>
            <div class="flex gap-3 mt-3">
              <div class="skeleton w-9 h-9 rounded-full flex-shrink-0"></div>
              <div class="flex-1 space-y-2">
                <div class="skeleton h-3.5 rounded w-5/6"></div>
                <div class="skeleton h-3 rounded w-3/4"></div>
                <div class="skeleton h-3 rounded w-1/2"></div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <section id="search-results" class="hidden opacity-0 transition-opacity duration-300">
        <h2 id="results-headline" class="text-base font-bold text-ink mb-4"></h2>
        <div id="results-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-6"></div>
        <div id="pagination" class="hidden flex items-center justify-center gap-3 mt-10">
          <button id="prev-page" class="flex items-center gap-1 h-9 px-4 bg-base-2 border border-white/10 text-ink text-sm rounded-full hover:bg-base-3 disabled:opacity-40 disabled:cursor-not-allowed">
            <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor" aria-hidden="true"><path d="M15 6l-6 6 6 6V6z"/></svg>
            Previous
          </button>
          <span id="page-info" class="text-sm text-ink-muted"></span>
          <button id="next-page" class="flex items-center gap-1 h-9 px-4 bg-base-2 border border-white/10 text-ink text-sm rounded-full hover:bg-base-3 disabled:opacity-40 disabled:cursor-not-allowed">
            Next
            <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor" aria-hidden="true"><path d="M9 6v12l6-6-6-6z"/></svg>
          </button>
        </div>
      </section>

      <div id="status-card" class="py-20 text-center">
        <div class="w-14 h-14 rounded-full bg-base-2 flex items-center justify-center mx-auto mb-4 text-ink-muted">
          <svg viewBox="0 0 24 24" class="w-6 h-6" fill="currentColor" aria-hidden="true">
            <path d="M10 4a6 6 0 1 0 3.815 10.65L18 18.835 19.415 17.42l-4.185-4.185A6 6 0 0 0 10 4zm0 2a4 4 0 1 1 0 8 4 4 0 0 1 0-8z" />
          </svg>
        </div>
        <p id="status-text" class="text-ink-muted text-sm">
          Enter a search query above to discover movies and television features.
        </p>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { tmdbApi } from '../lib/api';
  import { createMediaCardElement } from '../lib/mediaCardFactory';

  let currentPage = 1;
  let totalPages = 1;
  let currentQuery = '';

  function setStatus(text: string, icon: 'search' | 'none' = 'search') {
    const statusCard = document.getElementById('status-card');
    const statusText = document.getElementById('status-text');
    if (statusText) statusText.textContent = text;
    if (statusCard && icon === 'none') {
      const iconWrap = statusCard.querySelector('div:first-child');
      if (iconWrap) iconWrap.remove();
    }
    statusCard?.classList.remove('hidden');
  }

  let executeLibrarySearch = async (query: string, page: number = 1) => {
    const resultsBlock = document.getElementById('search-results');
    const skeletonGrid = document.getElementById('search-skeleton');
    const statusCard = document.getElementById('status-card');
    const resultsGrid = document.getElementById('results-grid');
    const headline = document.getElementById('results-headline');
    const pagination = document.getElementById('pagination');
    const pageInfo = document.getElementById('page-info');
    const prevBtn = document.getElementById('prev-page') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-page') as HTMLButtonElement;
    const filterBar = document.getElementById('filter-bar');

    currentQuery = query;
    currentPage = page;

    if (!query.trim()) {
      resultsBlock?.classList.add('hidden');
      skeletonGrid?.classList.add('hidden');
      filterBar?.classList.add('hidden');
      pagination?.classList.add('hidden');
      statusCard?.classList.remove('hidden');
      setStatus('Enter a search query above to discover movies and television features.');
      return;
    }

    filterBar?.classList.remove('hidden');
    statusCard?.classList.add('hidden');
    resultsBlock?.classList.add('hidden');
    skeletonGrid?.classList.remove('hidden');
    pagination?.classList.add('hidden');

    if (!resultsGrid) return;
    resultsGrid.replaceChildren();

    try {
      const typeFilter = (document.getElementById('type-filter') as HTMLSelectElement)?.value || 'multi';
      const genreFilter = (document.getElementById('genre-filter') as HTMLSelectElement)?.value || '';
      const yearFilter = (document.getElementById('year-filter') as HTMLInputElement)?.value || '';

      let response;
      if (genreFilter || yearFilter) {
        const searchType = typeFilter === 'multi' ? 'movie' : typeFilter;
        response = await tmdbApi.search(query, searchType as any, page);
      } else {
        response = await tmdbApi.search(query, typeFilter as any, page);
      }

      let hits = (response?.results || []).filter((item: any) => item.media_type !== 'person' && (item.poster_path || item.backdrop_path));

      if (genreFilter) {
        const genreId = parseInt(genreFilter);
        hits = hits.filter((item: any) => item.genre_ids?.includes(genreId));
      }
      if (yearFilter) {
        const y = parseInt(yearFilter);
        hits = hits.filter((item: any) => {
          const year = (item.release_date || item.first_air_date || '').split('-')[0];
          return year === String(y);
        });
      }

      totalPages = Math.min(response?.total_pages || 1, 500);

      skeletonGrid?.classList.add('hidden');

      if (hits.length === 0) {
        statusCard?.classList.remove('hidden');
        setStatus(`No results found for "${query}". Try a different search.`);
        return;
      }

      if (headline) headline.textContent = `Results for "${query}"`;

      const docFragment = document.createDocumentFragment();
      hits.forEach((item: any) => {
        docFragment.appendChild(createMediaCardElement(item));
      });
      resultsGrid.appendChild(docFragment);

      resultsBlock?.classList.remove('hidden');
      setTimeout(() => resultsBlock?.classList.remove('opacity-0'), 50);

      if (totalPages > 1) {
        pagination?.classList.remove('hidden');
        if (pageInfo) pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
        if (prevBtn) prevBtn.disabled = currentPage <= 1;
        if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
      }

    } catch (err) {
      console.error('Search error:', err);
      skeletonGrid?.classList.add('hidden');
      statusCard?.classList.remove('hidden');
      setStatus('Network error. Failed to load results.');
    }
  };

  document.addEventListener('DOMContentLoaded', async () => {
    const form = document.getElementById('search-form') as HTMLFormElement;
    const input = document.getElementById('search-input') as HTMLInputElement;
    const genreFilter = document.getElementById('genre-filter') as HTMLSelectElement;
    const prevBtn = document.getElementById('prev-page');
    const nextBtn = document.getElementById('next-page');
    const resultsGrid = document.getElementById('results-grid');

    Promise.all([
      tmdbApi.genres('movie'),
      tmdbApi.genres('tv'),
    ]).then(([movieGenres, tvGenres]: any[]) => {
      const all = new Map<number, string>();
      (movieGenres.genres || []).forEach((g: any) => all.set(g.id, g.name));
      (tvGenres.genres || []).forEach((g: any) => all.set(g.id, g.name));
      for (const [id, name] of all) {
        const opt = document.createElement('option');
        opt.value = String(id);
        opt.textContent = name;
        genreFilter.appendChild(opt);
      }
    }).catch(() => {});

    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get('q');

    if (initialQuery && input) {
      input.value = initialQuery;
      input.focus();
      executeLibrarySearch(initialQuery);
    } else {
      input?.focus();
    }

    let debounceTimer: ReturnType<typeof setTimeout>;
    input?.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      const val = input.value.trim();
      debounceTimer = setTimeout(() => {
        if (val) {
          history.replaceState(null, '', `/search?q=${encodeURIComponent(val)}`);
          executeLibrarySearch(val);
        } else {
          history.replaceState(null, '', '/search');
          executeLibrarySearch('');
        }
      }, 350);
    });

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      clearTimeout(debounceTimer);
      const currentQuery = input.value.trim();
      if (currentQuery) {
        history.pushState(null, '', `/search?q=${encodeURIComponent(currentQuery)}`);
        executeLibrarySearch(currentQuery);
      }
    });

    genreFilter?.addEventListener('change', () => {
      if (currentQuery) executeLibrarySearch(currentQuery);
    });

    document.getElementById('type-filter')?.addEventListener('change', () => {
      if (currentQuery) executeLibrarySearch(currentQuery);
    });

    let yearDebounce: ReturnType<typeof setTimeout> | null = null;
    document.getElementById('year-filter')?.addEventListener('input', () => {
      if (!currentQuery) return;
      if (yearDebounce) clearTimeout(yearDebounce);
      yearDebounce = setTimeout(() => executeLibrarySearch(currentQuery), 350);
    });

    prevBtn?.addEventListener('click', () => {
      if (currentPage > 1) executeLibrarySearch(currentQuery, currentPage - 1);
    });

    nextBtn?.addEventListener('click', () => {
      if (currentPage < totalPages) executeLibrarySearch(currentQuery, currentPage + 1);
    });

    let focusedIndex = -1;
    input?.addEventListener('keydown', (e) => {
      if (!resultsGrid) return;
      const cards = resultsGrid.querySelectorAll<HTMLAnchorElement>('a');
      if (cards.length === 0) return;

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        focusedIndex = Math.min(focusedIndex + 1, cards.length - 1);
        cards[focusedIndex]?.focus();
        cards[focusedIndex]?.scrollIntoView({ block: 'nearest' });
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        focusedIndex = Math.max(focusedIndex - 1, 0);
        cards[focusedIndex]?.focus();
        cards[focusedIndex]?.scrollIntoView({ block: 'nearest' });
      } else if (e.key === 'Escape') {
        e.preventDefault();
        focusedIndex = -1;
        input?.focus();
      }
    });

    const origExecute = executeLibrarySearch;
    executeLibrarySearch = function(...args: any[]) {
      focusedIndex = -1;
      return (origExecute as any).apply(this, args);
    };
  });
</script>
