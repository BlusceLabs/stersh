---
import Layout from '../layouts/Layout.astro';
import MovieCard from '../components/MovieCard.svelte';

const results = [
  { id: 1, title: 'Inception', year: '2010', poster: '/placeholder-movie.jpg', rating: 8.8 },
  { id: 2, title: 'The Matrix', year: '1999', poster: '/placeholder-movie.jpg', rating: 8.7 },
];
---

<Layout title="Watchfy - Search">
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-white mb-6">Search</h1>
    
    <form class="max-w-2xl mb-8">
      <div class="relative">
        <input
          type="text"
          placeholder="Search movies, TV shows..."
          class="w-full px-6 py-4 bg-zinc-800 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-yellow-500"
        />
        <button type="submit" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white">
          Search
        </button>
      </div>
    </form>
    
    {results.length > 0 && (
      <>
        <h2 class="text-xl font-semibold text-white mb-4">Results</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
          {results.map(item => (
            <MovieCard client:load id={item.id} title={item.title} year={item.year} poster={item.poster} rating={item.rating} />
          ))}
        </div>
      </>
    )}
  </main>
</Layout>