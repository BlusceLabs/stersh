---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Search Catalog | Watchfy">
  <main class="min-h-screen bg-surface-0 text-ink pt-8 sm:pt-12 pb-32 lg:pb-28 select-none relative overflow-x-hidden">
    <div class="absolute top-0 right-1/4 w-[600px] h-[300px] bg-brand-cyan/[0.04] rounded-full blur-[140px] pointer-events-none z-0" aria-hidden="true"></div>
    <div class="absolute top-1/2 left-1/4 w-[400px] h-[300px] bg-brand-red/[0.03] rounded-full blur-[140px] pointer-events-none z-0" aria-hidden="true"></div>

    <div class="relative z-10 max-w-content mx-auto px-4 sm:px-6 lg:px-8">

      <header class="mb-6">
        <p class="text-[11px] uppercase tracking-[0.3em] font-bold text-brand-cyan mb-1.5">Discover</p>
        <h1 class="text-2xl sm:text-4xl lg:text-display-lg font-display font-black text-ink tracking-tighter">
          Search Library
        </h1>
        <p class="text-xs sm:text-sm text-ink-muted mt-1 font-medium">Discover movies and TV shows by title, genre, or year.</p>
      </header>

      <form id="search-form" class="max-w-3xl mb-6 group">
        <label for="search-input" class="sr-only">Search</label>
        <div class="relative">
          <input
            id="search-input"
            type="text"
            name="q"
            autocomplete="off"
            placeholder="Search titles, actors, genres..."
            class="w-full pl-14 pr-32 py-4 sm:py-5 bg-surface-1/60 text-ink font-medium placeholder-ink-subtle rounded-2xl border border-white/[0.06] focus:border-white/10 focus:outline-none focus:ring-4 focus:ring-brand-red/15 backdrop-blur-md transition-all duration-300 shadow-3"
          />

          <div class="absolute left-5 top-1/2 -translate-y-1/2 text-ink-subtle group-focus-within:text-brand-red transition-colors duration-300 pointer-events-none" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.604 10.604Z" />
            </svg>
          </div>

          <button
            type="submit"
            class="absolute right-2.5 top-1/2 -translate-y-1/2 px-5 py-2.5 sm:py-3 bg-brand-gradient-cta text-white font-bold text-xs uppercase tracking-wider rounded-xl hover:brightness-110 active:scale-95 shadow-glow-red transition-all duration-300 ease-exo-out"
          >
            Search
          </button>
        </div>
      </form>

      <div id="filter-bar" class="hidden flex flex-wrap items-center gap-2.5 mb-8 max-w-3xl">
        <div class="relative">
          <select id="type-filter" class="appearance-none bg-surface-1/60 border border-white/[0.06] text-ink-secondary text-xs font-bold pl-3.5 pr-9 py-2.5 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-red/30 cursor-pointer hover:border-white/10 transition-colors">
            <option value="multi">All Types</option>
            <option value="movie">Movies</option>
            <option value="tv">TV Shows</option>
          </select>
          <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-ink-subtle pointer-events-none" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
        </div>
        <div class="relative">
          <select id="genre-filter" class="appearance-none bg-surface-1/60 border border-white/[0.06] text-ink-secondary text-xs font-bold pl-3.5 pr-9 py-2.5 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-red/30 cursor-pointer hover:border-white/10 transition-colors">
            <option value="">All Genres</option>
          </select>
          <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-ink-subtle pointer-events-none" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
        </div>
        <input
          type="number"
          id="year-filter"
          placeholder="Year"
          min="1900"
          max="2030"
          class="w-24 bg-surface-1/60 border border-white/[0.06] text-ink-secondary text-xs font-bold px-3.5 py-2.5 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-red/30 placeholder-ink-subtle hover:border-white/10 transition-colors"
        />
      </div>

      <div id="search-skeleton" class="hidden grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-x-4 gap-y-8">
        {Array.from({ length: 6 }).map(() => (
          <div class="space-y-3">
            <div class="skeleton aspect-[2/3] rounded-2xl"></div>
            <div class="space-y-2 px-1">
              <div class="skeleton h-3.5 rounded w-5/6"></div>
              <div class="skeleton h-2.5 rounded w-1/2"></div>
            </div>
          </div>
        ))}
      </div>

      <section id="search-results" class="hidden opacity-0 transition-opacity duration-400">
        <h2 id="results-headline" class="text-xs font-black uppercase tracking-[0.18em] text-ink-muted mb-6 border-b border-white/[0.06] pb-3">
          Search Results
        </h2>
        <div id="results-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-x-4 gap-y-8"></div>
        <div id="pagination" class="hidden flex items-center justify-center gap-4 mt-10">
          <button id="prev-page" class="px-4 py-2.5 bg-surface-1/60 border border-white/[0.06] text-ink-secondary text-xs font-bold rounded-xl hover:bg-surface-2/60 hover:text-ink transition-all disabled:opacity-30 disabled:cursor-not-allowed">Previous</button>
          <span id="page-info" class="text-xs text-ink-muted font-medium"></span>
          <button id="next-page" class="px-4 py-2.5 bg-surface-1/60 border border-white/[0.06] text-ink-secondary text-xs font-bold rounded-xl hover:bg-surface-2/60 hover:text-ink transition-all disabled:opacity-30 disabled:cursor-not-allowed">Next</button>
        </div>
      </section>

      <div id="status-card" class="py-20 text-center surface-elevated rounded-2xl p-8 backdrop-blur-sm max-w-md mx-auto">
        <div class="w-14 h-14 rounded-2xl bg-surface-2 flex items-center justify-center mx-auto mb-4 border border-white/[0.06] text-brand-cyan">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.604 10.604Z" />
          </svg>
        </div>
        <p id="status-text" class="text-ink-secondary text-sm font-medium">
          Enter a search query above to discover movies and television features.
        </p>
      </div>

    </div>
  </main>
</Layout>

<script>
  import { tmdbApi } from '../lib/api';
  import { createMediaCardElement } from '../lib/mediaCardFactory';

  let currentPage = 1;
  let totalPages = 1;
  let currentQuery = '';

  let executeLibrarySearch = async (query: string, page: number = 1) => {
    const resultsBlock = document.getElementById('search-results');
    const skeletonGrid = document.getElementById('search-skeleton');
    const statusCard = document.getElementById('status-card');
    const statusText = document.getElementById('status-text');
    const resultsGrid = document.getElementById('results-grid');
    const headline = document.getElementById('results-headline');
    const pagination = document.getElementById('pagination');
    const pageInfo = document.getElementById('page-info');
    const prevBtn = document.getElementById('prev-page') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-page') as HTMLButtonElement;
    const filterBar = document.getElementById('filter-bar');

    currentQuery = query;
    currentPage = page;

    if (!query.trim()) {
      resultsBlock?.classList.add('hidden');
      skeletonGrid?.classList.add('hidden');
      filterBar?.classList.add('hidden');
      pagination?.classList.add('hidden');
      statusCard?.classList.remove('hidden');
      if (statusText) statusText.textContent = "Enter a search query above to discover movies and television features.";
      return;
    }

    filterBar?.classList.remove('hidden');
    statusCard?.classList.add('hidden');
    resultsBlock?.classList.add('hidden');
    skeletonGrid?.classList.remove('hidden');
    pagination?.classList.add('hidden');

    if (!resultsGrid) return;
    resultsGrid.replaceChildren();

    try {
      const typeFilter = (document.getElementById('type-filter') as HTMLSelectElement)?.value || 'multi';
      const genreFilter = (document.getElementById('genre-filter') as HTMLSelectElement)?.value || '';
      const yearFilter = (document.getElementById('year-filter') as HTMLInputElement)?.value || '';

      let response;
      if (genreFilter || yearFilter) {
        const searchType = typeFilter === 'multi' ? 'movie' : typeFilter;
        response = await tmdbApi.search(query, searchType as any, page);
      } else {
        response = await tmdbApi.search(query, typeFilter as any, page);
      }

      let hits = (response?.results || []).filter((item: any) => item.media_type !== 'person' && (item.poster_path || item.backdrop_path));

      if (genreFilter) {
        const genreId = parseInt(genreFilter);
        hits = hits.filter((item: any) => item.genre_ids?.includes(genreId));
      }
      if (yearFilter) {
        const y = parseInt(yearFilter);
        hits = hits.filter((item: any) => {
          const year = (item.release_date || item.first_air_date || '').split('-')[0];
          return year === String(y);
        });
      }

      totalPages = Math.min(response?.total_pages || 1, 500);

      skeletonGrid.classList.add('hidden');

      if (hits.length === 0) {
        statusCard?.classList.remove('hidden');
        statusCard.innerHTML = `
          <div class="w-14 h-14 rounded-2xl bg-surface-2 flex items-center justify-center mx-auto mb-4 border border-white/[0.06] text-ink-muted">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 5.25h16.5m-16.5-10.5h16.5" />
            </svg>
          </div>
          <h3 class="text-base font-bold text-ink mb-1">No results found</h3>
          <p class="text-sm text-ink-muted">Nothing matched "${query.replace(/[<>&"]/g, '')}". Try a different search.</p>
        `;
        return;
      }

      if (headline) headline.textContent = `Results for "${query}"`;

      const docFragment = document.createDocumentFragment();
      hits.forEach((item: any) => {
        docFragment.appendChild(createMediaCardElement(item));
      });
      resultsGrid.appendChild(docFragment);

      resultsBlock.classList.remove('hidden');
      setTimeout(() => resultsBlock.classList.remove('opacity-0'), 50);

      if (totalPages > 1) {
        pagination?.classList.remove('hidden');
        if (pageInfo) pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
        if (prevBtn) prevBtn.disabled = currentPage <= 1;
        if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
      }

    } catch (err) {
      console.error('Search error:', err);
      skeletonGrid.classList.add('hidden');
      statusCard?.classList.remove('hidden');
      statusCard.innerHTML = `
        <div class="w-14 h-14 rounded-2xl bg-brand-red/[0.06] border border-brand-red/20 flex items-center justify-center mx-auto mb-4 text-brand-red">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
          </svg>
        </div>
        <h3 class="text-base font-bold text-ink mb-1">Network Error</h3>
        <p class="text-sm text-ink-muted">Failed to load results.</p>
      `;
    }
  };

  document.addEventListener('DOMContentLoaded', async () => {
    const form = document.getElementById('search-form') as HTMLFormElement;
    const input = document.getElementById('search-input') as HTMLInputElement;
    const genreFilter = document.getElementById('genre-filter') as HTMLSelectElement;
    const prevBtn = document.getElementById('prev-page');
    const nextBtn = document.getElementById('next-page');
    const resultsGrid = document.getElementById('results-grid');

    Promise.all([
      tmdbApi.genres('movie'),
      tmdbApi.genres('tv'),
    ]).then(([movieGenres, tvGenres]: any[]) => {
      const all = new Map<number, string>();
      (movieGenres.genres || []).forEach((g: any) => all.set(g.id, g.name));
      (tvGenres.genres || []).forEach((g: any) => all.set(g.id, g.name));
      for (const [id, name] of all) {
        const opt = document.createElement('option');
        opt.value = String(id);
        opt.textContent = name;
        genreFilter.appendChild(opt);
      }
    }).catch(() => {});

    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get('q');

    if (initialQuery && input) {
      input.value = initialQuery;
      input.focus();
      executeLibrarySearch(initialQuery);
    } else {
      input?.focus();
    }

    let debounceTimer: ReturnType<typeof setTimeout>;
    input?.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      const val = input.value.trim();
      debounceTimer = setTimeout(() => {
        if (val) {
          history.replaceState(null, '', `/search?q=${encodeURIComponent(val)}`);
          executeLibrarySearch(val);
        } else {
          history.replaceState(null, '', '/search');
          executeLibrarySearch('');
        }
      }, 350);
    });

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      clearTimeout(debounceTimer);
      const currentQuery = input.value.trim();
      if (currentQuery) {
        history.pushState(null, '', `/search?q=${encodeURIComponent(currentQuery)}`);
        executeLibrarySearch(currentQuery);
      }
    });

    genreFilter?.addEventListener('change', () => {
      if (currentQuery) executeLibrarySearch(currentQuery);
    });

    document.getElementById('type-filter')?.addEventListener('change', () => {
      if (currentQuery) executeLibrarySearch(currentQuery);
    });

    let yearDebounce: ReturnType<typeof setTimeout> | null = null;
    document.getElementById('year-filter')?.addEventListener('input', () => {
      if (!currentQuery) return;
      if (yearDebounce) clearTimeout(yearDebounce);
      yearDebounce = setTimeout(() => executeLibrarySearch(currentQuery), 350);
    });

    prevBtn?.addEventListener('click', () => {
      if (currentPage > 1) executeLibrarySearch(currentQuery, currentPage - 1);
    });

    nextBtn?.addEventListener('click', () => {
      if (currentPage < totalPages) executeLibrarySearch(currentQuery, currentPage + 1);
    });

    let focusedIndex = -1;
    input?.addEventListener('keydown', (e) => {
      if (!resultsGrid) return;
      const cards = resultsGrid.querySelectorAll<HTMLAnchorElement>('a');
      if (cards.length === 0) return;

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        focusedIndex = Math.min(focusedIndex + 1, cards.length - 1);
        cards[focusedIndex]?.focus();
        cards[focusedIndex]?.scrollIntoView({ block: 'nearest' });
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        focusedIndex = Math.max(focusedIndex - 1, 0);
        cards[focusedIndex]?.focus();
        cards[focusedIndex]?.scrollIntoView({ block: 'nearest' });
      } else if (e.key === 'Escape') {
        e.preventDefault();
        focusedIndex = -1;
        input?.focus();
      }
    });

    const origExecute = executeLibrarySearch;
    executeLibrarySearch = function(...args) {
      focusedIndex = -1;
      return origExecute.apply(this, args);
    };
  });
</script>
