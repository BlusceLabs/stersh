---
import Layout from '../../layouts/Layout.astro';
import FilterChips from '../../components/FilterChips.svelte';

const { id } = Astro.params;
---

<Layout title="Genre | Stersh">
  <main class="min-h-screen bg-base">
    <div class="px-4 md:px-6 pt-2">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="text-2xl font-bold text-ink" id="genre-title">Loading...</h1>
        <span class="text-sm text-ink-muted"><span id="item-count">0</span> titles</span>
      </div>

      <div id="filter-bar" class="mb-6">
        <FilterChips
          chips={[
            { id: 'all', label: 'All' },
            { id: 'movies', label: 'Movies' },
            { id: 'tv', label: 'TV Shows' },
          ]}
          active="all"
          hrefBuilder={(id) => '#'}
        />

        <div class="flex flex-wrap items-center gap-2 mt-3">
          <div class="relative">
            <select id="sort-filter" class="appearance-none bg-base-2 border border-white/10 text-ink text-sm pl-3 pr-9 py-2 rounded-full focus:outline-none focus:border-yt-blue cursor-pointer hover:bg-base-3">
              <option value="popularity.desc">Popular</option>
              <option value="vote_average.desc">Top Rated</option>
              <option value="primary_release_date.desc">Newest</option>
              <option value="revenue.desc">Top Grossing</option>
            </select>
            <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-ink-muted pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
          </div>
          <div class="flex items-center gap-2 ml-auto">
            <button id="prev-page" class="flex items-center gap-1 h-9 px-4 bg-base-2 border border-white/10 text-ink text-sm rounded-full hover:bg-base-3 disabled:opacity-40 disabled:cursor-not-allowed" disabled>
              <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor" aria-hidden="true"><path d="M15 6l-6 6 6 6V6z"/></svg>
              Prev
            </button>
            <span id="page-info" class="text-sm text-ink-muted">Page 1</span>
            <button id="next-page" class="flex items-center gap-1 h-9 px-4 bg-base-2 border border-white/10 text-ink text-sm rounded-full hover:bg-base-3 disabled:opacity-40 disabled:cursor-not-allowed">
              Next
              <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor" aria-hidden="true"><path d="M9 6v12l6-6-6-6z"/></svg>
            </button>
          </div>
        </div>
      </div>

      <div id="content-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-6 opacity-0 transition-opacity duration-300"></div>

      <div id="grid-skeleton" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-6">
        {Array.from({ length: 12 }).map(() => (
          <div>
            <div class="skeleton aspect-video rounded-xl"></div>
            <div class="flex gap-3 mt-3">
              <div class="skeleton w-9 h-9 rounded-full flex-shrink-0"></div>
              <div class="flex-1 space-y-2">
                <div class="skeleton h-3.5 rounded w-5/6"></div>
                <div class="skeleton h-3 rounded w-3/4"></div>
                <div class="skeleton h-3 rounded w-1/2"></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>

<script>
  import { tmdbApi } from '../../lib/api';
  import { createMediaCardElement } from '../../lib/mediaCardFactory';

  const genreId = window.location.pathname.split('/').pop() || '';
  let currentPage = 1;
  let totalPages = 1;
  let currentFilter: 'all' | 'movies' | 'tv' = 'all';
  let currentSort = 'popularity.desc';
  let abortCtl: AbortController | null = null;

  function setActiveChip() {
    const idx = ['all', 'movies', 'tv'].indexOf(currentFilter);
    document.querySelectorAll('#filter-bar [data-active]').forEach((el, i) => {
      el.setAttribute('data-active', i === idx ? 'true' : 'false');
    });
  }

  async function loadGenreName() {
    try {
      const [movieGenres, tvGenres] = await Promise.all([
        tmdbApi.genres('movie'),
        tmdbApi.genres('tv'),
      ]);
      const allGenres = [...(movieGenres.genres || []), ...(tvGenres.genres || [])];
      const genre = allGenres.find((g: any) => String(g.id) === genreId);
      if (genre) {
        const titleEl = document.getElementById('genre-title');
        if (titleEl) titleEl.textContent = genre.name;
        document.title = `${genre.name} | Stersh`;
      }
    } catch {}
  }

  async function loadContent() {
    const grid = document.getElementById('content-grid');
    const skeleton = document.getElementById('grid-skeleton');
    const prevBtn = document.getElementById('prev-page') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-page') as HTMLButtonElement;
    const pageInfo = document.getElementById('page-info');
    if (!grid || !skeleton) return;

    abortCtl?.abort();
    abortCtl = new AbortController();
    const signal = abortCtl.signal;

    skeleton.style.display = '';
    grid.classList.add('opacity-0');
    grid.replaceChildren();

    try {
      const sortsForTV = new Set([
        'primary_release_date.desc',
        'revenue.desc',
      ]);
      const baseYear = new Date().getFullYear();

      const fetches: Promise<any>[] = [];
      const fetchMedia: ('movie' | 'tv')[] = [];

      if (currentFilter === 'all' || currentFilter === 'movies') {
        fetchMedia.push('movie');
        fetches.push(tmdbApi.discover('movie', {
          with_genres: genreId,
          sort_by: currentSort,
          page: currentPage,
          vote_count_gte: 10,
        }));
      }
      if (currentFilter === 'all' || currentFilter === 'tv') {
        fetchMedia.push('tv');
        const sortBy = sortsForTV.has(currentSort) ? 'popularity.desc' : currentSort;
        fetches.push(tmdbApi.discover('tv', {
          with_genres: genreId,
          sort_by: sortBy,
          page: currentPage,
          vote_count_gte: 10,
        }));
      }

      const responses = await Promise.all(fetches);
      if (signal.aborted) return;

      let allItems: any[] = [];
      responses.forEach((res, i) => {
        const mt = fetchMedia[i];
        const items = (res?.results || [])
          .filter((m: any) => m.poster_path || m.backdrop_path)
          .map((m: any) => ({ ...m, media_type: mt }));
        allItems.push(...items);
      });

      totalPages = Math.min(
        ...responses.map((r: any) => r?.total_pages || 1),
        500,
      );

      const fragment = document.createDocumentFragment();
      allItems.forEach((item: any) => {
        fragment.appendChild(createMediaCardElement(item));
      });
      grid.appendChild(fragment);

      skeleton.style.display = 'none';
      grid.classList.remove('opacity-0');

      const countEl = document.getElementById('item-count');
      if (countEl) countEl.textContent = String(allItems.length);
      if (pageInfo) pageInfo.textContent = `Page ${currentPage}`;
      prevBtn.disabled = currentPage <= 1;
      nextBtn.disabled = currentPage >= totalPages;
    } catch (e) {
      if ((e as any)?.name === 'AbortError') return;
      console.error('Genre load error:', e);
      skeleton.style.display = 'none';
    }
  }

  document.addEventListener('DOMContentLoaded', async () => {
    await loadGenreName();
    loadContent();

    document.querySelectorAll('#filter-bar [data-active]').forEach((el, i) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        currentFilter = ['all', 'movies', 'tv'][i] as typeof currentFilter;
        currentPage = 1;
        setActiveChip();
        loadContent();
      });
    });

    document.getElementById('sort-filter')?.addEventListener('change', (e) => {
      currentSort = (e.currentTarget as HTMLSelectElement).value;
      currentPage = 1;
      loadContent();
    });
    document.getElementById('prev-page')?.addEventListener('click', () => { if (currentPage > 1) { currentPage--; loadContent(); } });
    document.getElementById('next-page')?.addEventListener('click', () => { if (currentPage < totalPages) { currentPage++; loadContent(); } });
  });
</script>
