---
import Layout from '../../layouts/Layout.astro';

const { id } = Astro.params;
---

<Layout title="Browse by Genre | Watchfy">
  <main class="min-h-screen bg-surface-0 text-ink pt-8 sm:pt-12 pb-32 lg:pb-28 select-none relative overflow-x-hidden">
    <div class="absolute top-0 left-1/4 w-[500px] h-[350px] bg-brand-red/[0.04] rounded-full blur-[120px] pointer-events-none z-0" aria-hidden="true"></div>
    <div class="absolute top-1/3 right-1/4 w-[400px] h-[300px] bg-brand-purple/[0.04] rounded-full blur-[140px] pointer-events-none z-0" aria-hidden="true"></div>

    <div class="relative z-10 max-w-content mx-auto px-4 sm:px-6 lg:px-8">

      <header class="border-b border-white/[0.06] pb-5 mb-6 sm:mb-8 flex flex-col sm:flex-row sm:items-end justify-between gap-4">
        <div>
          <p class="text-[11px] uppercase tracking-[0.3em] font-bold text-brand-red mb-1.5">Explore</p>
          <h1 class="text-2xl sm:text-4xl lg:text-display-lg font-display font-black text-ink tracking-tighter" id="genre-title">
            Loading...
          </h1>
          <p class="text-xs sm:text-sm text-ink-muted mt-1 font-medium" id="genre-description">Browse movies and TV shows by genre.</p>
        </div>

        <div class="flex items-center gap-2.5">
          <div class="bg-surface-1/60 border border-white/[0.06] rounded-xl px-3.5 py-2 backdrop-blur-md">
            <span class="text-[11px] font-bold text-ink-secondary tracking-wider uppercase">
              <span id="item-count" class="text-ink">0</span> titles
            </span>
          </div>
        </div>
      </header>

      <!-- Filter tabs -->
      <div class="flex items-center gap-2 mb-8">
        <button id="filter-all" class="filter-tab active px-4 py-2 rounded-xl text-xs font-bold transition-all duration-200">
          All
        </button>
        <button id="filter-movies" class="filter-tab px-4 py-2 rounded-xl text-xs font-bold transition-all duration-200">
          Movies
        </button>
        <button id="filter-tv" class="filter-tab px-4 py-2 rounded-xl text-xs font-bold transition-all duration-200">
          TV Shows
        </button>
      </div>

      <!-- Sort and pagination -->
      <div class="flex flex-wrap items-center gap-2.5 mb-8">
        <div class="relative">
          <select id="sort-filter" class="appearance-none bg-surface-1/60 border border-white/[0.06] text-ink-secondary text-xs font-bold pl-3.5 pr-9 py-2.5 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-red/30 cursor-pointer hover:border-white/10 hover:bg-surface-2/40 transition-all duration-200">
            <option value="popular">Popular</option>
            <option value="top_rated">Top Rated</option>
            <option value="now_playing">Now Playing</option>
            <option value="upcoming">Upcoming</option>
          </select>
          <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-ink-subtle pointer-events-none" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
        </div>
        <div class="flex items-center gap-2 ml-auto">
          <button id="prev-page" class="px-3.5 py-2.5 bg-surface-1/60 border border-white/[0.06] text-ink-secondary text-xs font-bold rounded-xl hover:bg-surface-2/60 hover:text-ink transition-all disabled:opacity-30 disabled:cursor-not-allowed transform hover:scale-[1.03] active:scale-95 disabled:hover:scale-100" disabled>
            Prev
          </button>
          <span id="page-info" class="text-xs text-ink-muted font-medium px-1">Page 1</span>
          <button id="next-page" class="px-3.5 py-2.5 bg-surface-1/60 border border-white/[0.06] text-ink-secondary text-xs font-bold rounded-xl hover:bg-surface-2/60 hover:text-ink transition-all disabled:opacity-30 disabled:cursor-not-allowed transform hover:scale-[1.03] active:scale-95 disabled:hover:scale-100">
            Next
          </button>
        </div>
      </div>

      <!-- Content grid -->
      <div id="content-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-x-4 gap-y-8 opacity-0 transition-opacity duration-500"></div>

      <!-- Loading skeleton -->
      <div id="grid-skeleton" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-x-4 gap-y-8">
        {Array.from({ length: 12 }).map((_, i) => (
          <div class="space-y-3" style="animation-delay: {Math.min(i * 50, 300)}ms">
            <div class="skeleton aspect-[2/3] rounded-2xl rise-in"></div>
            <div class="space-y-2 px-1">
              <div class="skeleton h-3.5 rounded w-5/6"></div>
              <div class="skeleton h-2.5 rounded w-1/2"></div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </main>
</Layout>

<style>
  .filter-tab {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    color: var(--color-ink-subtle);
  }
  .filter-tab:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-ink-secondary);
  }
  .filter-tab.active {
    background: rgba(239, 68, 68, 0.12);
    border-color: rgba(239, 68, 68, 0.25);
    color: var(--color-brand-red);
  }
</style>

<script>
  import { tmdbApi } from '../../lib/api';
  import { createMediaCardElement } from '../../lib/mediaCardFactory';

  const genreId = window.location.pathname.split('/').pop() || '';
  let currentPage = 1;
  let totalPages = 1;
  let currentFilter: 'all' | 'movies' | 'tv' = 'all';
  let genreName = '';

  async function loadGenreName() {
    try {
      const [movieGenres, tvGenres] = await Promise.all([
        tmdbApi.genres('movie'),
        tmdbApi.genres('tv'),
      ]);

      const allGenres = [...(movieGenres.genres || []), ...(tvGenres.genres || [])];
      const genre = allGenres.find((g: any) => String(g.id) === genreId);

      if (genre) {
        genreName = genre.name;
        const titleEl = document.getElementById('genre-title');
        if (titleEl) titleEl.textContent = genre.name;
        document.title = `${genre.name} | Watchfy`;
      }
    } catch {}
  }

  async function loadContent() {
    const grid = document.getElementById('content-grid');
    const skeleton = document.getElementById('grid-skeleton');
    const prevBtn = document.getElementById('prev-page') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-page') as HTMLButtonElement;
    const pageInfo = document.getElementById('page-info');
    if (!grid || !skeleton) return;

    skeleton.style.display = '';
    grid.classList.add('opacity-0');
    grid.replaceChildren();

    const sort = (document.getElementById('sort-filter') as HTMLSelectElement)?.value || 'popular';

    try {
      let allItems: any[] = [];

      // Fetch movies if not filtering TV only
      if (currentFilter === 'all' || currentFilter === 'movies') {
        const movieParams: any = { with_genres: genreId, page: currentPage };
        let movieRes;
        if (sort === 'top_rated') {
          movieRes = await tmdbApi.topRated('movie', currentPage);
        } else {
          movieRes = await tmdbApi.popular('movie', currentPage);
        }
        const movies = (movieRes?.results || [])
          .filter((m: any) => m.genre_ids?.includes(parseInt(genreId)))
          .map((m: any) => ({ ...m, media_type: 'movie' }));
        allItems.push(...movies);
      }

      // Fetch TV if not filtering movies only
      if (currentFilter === 'all' || currentFilter === 'tv') {
        let tvRes;
        if (sort === 'top_rated') {
          tvRes = await tmdbApi.topRated('tv', currentPage);
        } else {
          tvRes = await tmdbApi.popular('tv', currentPage);
        }
        const tvShows = (tvRes?.results || [])
          .filter((t: any) => t.genre_ids?.includes(parseInt(genreId)))
          .map((t: any) => ({ ...t, media_type: 'tv' }));
        allItems.push(...tvShows);
      }

      totalPages = 500; // TMDB max

      const fragment = document.createDocumentFragment();
      allItems.forEach((item: any) => {
        fragment.appendChild(createMediaCardElement(item));
      });
      grid.appendChild(fragment);

      skeleton.style.display = 'none';
      grid.classList.remove('opacity-0');

      const countEl = document.getElementById('item-count');
      if (countEl) countEl.textContent = String(allItems.length);
      if (pageInfo) pageInfo.textContent = `Page ${currentPage}`;
      prevBtn.disabled = currentPage <= 1;
      nextBtn.disabled = currentPage >= totalPages;
    } catch (e) {
      console.error('Genre load error:', e);
      skeleton.style.display = 'none';
      grid.classList.remove('opacity-0');
    }
  }

  function setupFilters() {
    const filters: { id: string; type: typeof currentFilter }[] = [
      { id: 'filter-all', type: 'all' },
      { id: 'filter-movies', type: 'movies' },
      { id: 'filter-tv', type: 'tv' },
    ];

    filters.forEach(({ id, type }) => {
      const btn = document.getElementById(id);
      if (!btn) return;

      btn.addEventListener('click', () => {
        currentFilter = type;
        currentPage = 1;
        filters.forEach(f => {
          const el = document.getElementById(f.id);
          if (el) el.classList.toggle('active', f.type === type);
        });
        loadContent();
      });
    });
  }

  document.addEventListener('DOMContentLoaded', async () => {
    await loadGenreName();
    loadContent();
    setupFilters();

    document.getElementById('sort-filter')?.addEventListener('change', () => { currentPage = 1; loadContent(); });
    document.getElementById('prev-page')?.addEventListener('click', () => { if (currentPage > 1) { currentPage--; loadContent(); } });
    document.getElementById('next-page')?.addEventListener('click', () => { if (currentPage < totalPages) { currentPage++; loadContent(); } });
  });
</script>