---
import Layout from '../layouts/Layout.astro';
import MovieCard from '../components/MovieCard.svelte';

const movies = [
  { id: 1, title: 'Inception', year: '2010', poster: '/placeholder-movie.jpg', rating: 8.8 },
  { id: 2, title: 'The Matrix', year: '1999', poster: '/placeholder-movie.jpg', rating: 8.7 },
  { id: 3, title: 'Interstellar', year: '2014', poster: '/placeholder-movie.jpg', rating: 8.6 },
];
---

<Layout title="Watchfy - Movies">
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-white mb-6">Movies</h1>
    
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
      {movies.map(movie => (
        <MovieCard client:load id={movie.id} title={movie.title} year={movie.year} poster={movie.poster} rating={movie.rating} />
      ))}
    </div>
  </main>
</Layout>