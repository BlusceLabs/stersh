---
import Layout from '../layouts/Layout.astro';
import FilterChips from '../components/FilterChips.svelte';

const sortChips = [
  { id: 'popular', label: 'Popular' },
  { id: 'top_rated', label: 'Top Rated' },
  { id: 'now_playing', label: 'Now Playing' },
  { id: 'upcoming', label: 'Upcoming' },
];
---

<Layout title="Movies" description="Browse popular, top rated, now playing, and upcoming movies on Stersh.">
  <main class="min-h-screen bg-base">
    <div class="px-4 md:px-6 pt-2">
      <div class="flex items-center gap-3 mb-3">
        <h1 class="text-2xl font-bold text-ink">Movies</h1>
        <span class="text-sm text-ink-muted"><span id="movie-count">—</span> titles</span>
      </div>

      <div id="filter-bar" class="mb-6">
        <FilterChips
          chips={sortChips}
          active="popular"
          hrefBuilder={(id) => `/movies?sort=${id}`}
        />
        <div class="flex flex-wrap items-center gap-2 mt-3">
          <div class="relative">
            <select id="genre-filter" class="appearance-none bg-base-2 border border-white/10 text-ink text-sm pl-3 pr-9 py-2 rounded-full focus:outline-none focus:border-yt-blue cursor-pointer hover:bg-base-3">
              <option value="">All Genres</option>
            </select>
            <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-ink-muted pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
          </div>
          <div class="flex items-center gap-2 ml-auto">
            <button id="prev-page" class="flex items-center gap-1 h-9 px-4 bg-base-2 border border-white/10 text-ink text-sm rounded-full hover:bg-base-3 disabled:opacity-40 disabled:cursor-not-allowed" disabled>
              <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor" aria-hidden="true"><path d="M15 6l-6 6 6 6V6z"/></svg>
              Prev
            </button>
            <span id="page-info" class="text-sm text-ink-muted">Page 1</span>
            <button id="next-page" class="flex items-center gap-1 h-9 px-4 bg-base-2 border border-white/10 text-ink text-sm rounded-full hover:bg-base-3 disabled:opacity-40 disabled:cursor-not-allowed">
              Next
              <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor" aria-hidden="true"><path d="M9 6v12l6-6-6-6z"/></svg>
            </button>
          </div>
        </div>
      </div>

      <div id="movies-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-6 opacity-0 transition-opacity duration-300"></div>

      <div id="grid-skeleton" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-6">
        {Array.from({ length: 12 }).map((_, i) => (
          <div style="animation-delay: {Math.min(i * 30, 240)}ms">
            <div class="skeleton aspect-video rounded-xl"></div>
            <div class="flex gap-3 mt-3">
              <div class="skeleton w-9 h-9 rounded-full flex-shrink-0"></div>
              <div class="flex-1 space-y-2">
                <div class="skeleton h-3.5 rounded w-5/6"></div>
                <div class="skeleton h-3 rounded w-3/4"></div>
                <div class="skeleton h-3 rounded w-1/2"></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>

<script>
  import { tmdbApi } from '../lib/api';
  import { createMediaCardElement } from '../lib/mediaCardFactory';

  let currentPage = 1;
  let totalPages = 1;
  let currentSort = 'popular';

  function setActiveChip() {
    const params = new URLSearchParams(window.location.search);
    currentSort = params.get('sort') || 'popular';
    document.querySelectorAll('#filter-bar [data-active]').forEach((el) => {
      const isActive = el.textContent.trim().toLowerCase().replace(/\s+/g, '_') === currentSort
        || (currentSort === 'popular' && el.textContent.trim() === 'Popular');
      el.setAttribute('data-active', isActive ? 'true' : 'false');
    });
  }

  function syncUrl() {
    const url = new URL(window.location.href);
    url.searchParams.set('sort', currentSort);
    window.history.replaceState({}, '', url.toString());
  }

  async function loadMovies() {
    const grid = document.getElementById('movies-grid');
    const skeleton = document.getElementById('grid-skeleton');
    const prevBtn = document.getElementById('prev-page') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-page') as HTMLButtonElement;
    const pageInfo = document.getElementById('page-info');
    if (!grid || !skeleton) return;

    skeleton.style.display = '';
    grid.classList.add('opacity-0');
    grid.replaceChildren();

    const genreId = (document.getElementById('genre-filter') as HTMLSelectElement)?.value || '';

    try {
      let response;
      if (currentSort === 'top_rated') {
        response = await tmdbApi.topRated('movie', currentPage);
      } else if (currentSort === 'now_playing') {
        response = await fetch(`/api/tmdb/movie/now_playing?page=${currentPage}`).then(r => r.json());
      } else if (currentSort === 'upcoming') {
        response = await fetch(`/api/tmdb/movie/upcoming?page=${currentPage}`).then(r => r.json());
      } else {
        response = await tmdbApi.popular('movie', currentPage);
      }

      let movies = response?.results || [];
      totalPages = Math.min(response?.total_pages || 1, 500);

      if (genreId) {
        movies = movies.filter((m: any) => m.genre_ids?.includes(parseInt(genreId)));
      }

      const fragment = document.createDocumentFragment();
      movies.forEach((item: any) => {
        fragment.appendChild(createMediaCardElement({ ...item, media_type: 'movie' }));
      });
      grid.appendChild(fragment);

      skeleton.style.display = 'none';
      grid.classList.remove('opacity-0');

      const countEl = document.getElementById('movie-count');
      if (countEl) countEl.textContent = String(movies.length);
      if (pageInfo) pageInfo.textContent = `Page ${currentPage}`;
      prevBtn.disabled = currentPage <= 1;
      nextBtn.disabled = currentPage >= totalPages;
    } catch (e) {
      console.error('Movies load error:', e);
      skeleton.style.display = 'none';
      grid.classList.remove('opacity-0');
      grid.replaceChildren();
      const err = document.createElement('div');
      err.className = 'col-span-full py-16 text-center text-ink-muted';
      err.textContent = 'Could not load movies. Please try again.';
      grid.appendChild(err);
    }
  }

  async function loadGenres() {
    const genreFilter = document.getElementById('genre-filter') as HTMLSelectElement;
    try {
      const res = await tmdbApi.genres('movie');
      (res.genres || []).forEach((g: any) => {
        const opt = document.createElement('option');
        opt.value = String(g.id);
        opt.textContent = g.name;
        genreFilter.appendChild(opt);
      });
    } catch {}
  }

  document.addEventListener('DOMContentLoaded', async () => {
    setActiveChip();
    await loadGenres();
    loadMovies();

    document.querySelectorAll('#filter-bar [data-active]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        const chip = e.currentTarget as HTMLElement;
        const label = chip.textContent.trim().toLowerCase().replace(/\s+/g, '_');
        currentSort = label;
        currentPage = 1;
        syncUrl();
        setActiveChip();
        loadMovies();
      });
    });

    document.getElementById('genre-filter')?.addEventListener('change', () => { currentPage = 1; loadMovies(); });
    document.getElementById('prev-page')?.addEventListener('click', () => { if (currentPage > 1) { currentPage--; loadMovies(); } });
    document.getElementById('next-page')?.addEventListener('click', () => { if (currentPage < totalPages) { currentPage++; loadMovies(); } });
  });
</script>
