---
import Layout from '../layouts/Layout.astro';
import MediaRow from '../components/MediaRow.svelte';
import EmptyState from '../components/EmptyState.svelte';
---

<Layout title="Discover Movies | Watchfy">
  <main class="min-h-screen bg-surface-0 text-ink pt-20 sm:pt-24 pb-32 lg:pb-12 select-none relative overflow-x-hidden">
    <div class="absolute top-0 left-1/4 w-[500px] h-[350px] bg-brand-red/[0.04] rounded-full blur-[120px] pointer-events-none z-0" aria-hidden="true"></div>
    <div class="absolute top-1/3 right-1/4 w-[400px] h-[300px] bg-brand-purple/[0.04] rounded-full blur-[140px] pointer-events-none z-0" aria-hidden="true"></div>

    <div class="relative z-10 max-w-content mx-auto px-4 sm:px-6 lg:px-8">

      <header class="border-b border-white/[0.06] pb-5 mb-6 sm:mb-8 flex flex-col sm:flex-row sm:items-end justify-between gap-4">
        <div>
          <p class="text-[11px] uppercase tracking-[0.3em] font-bold text-brand-red mb-1.5">Catalog</p>
          <h1 class="text-2xl sm:text-4xl lg:text-display-lg font-display font-black text-ink tracking-tighter">
            Explore Movies
          </h1>
          <p class="text-xs sm:text-sm text-ink-muted mt-1 font-medium">Browse through our extensive movie catalog.</p>
        </div>

        <div class="flex items-center gap-2.5">
          <div class="bg-surface-1/60 border border-white/[0.06] rounded-xl px-3.5 py-2 backdrop-blur-md">
            <span class="text-[11px] font-bold text-ink-secondary tracking-wider uppercase">
              <span id="movie-count" class="text-ink">—</span> titles
            </span>
          </div>
        </div>
      </header>

      <div id="filter-bar" class="flex flex-wrap items-center gap-2.5 mb-8">
        <div class="relative">
          <select id="sort-filter" class="appearance-none bg-surface-1/60 border border-white/[0.06] text-ink-secondary text-xs font-bold pl-3.5 pr-9 py-2.5 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-red/30 cursor-pointer hover:border-white/10 hover:bg-surface-2/40 transition-all duration-200">
            <option value="popular">Popular</option>
            <option value="top_rated">Top Rated</option>
            <option value="now_playing">Now Playing</option>
            <option value="upcoming">Upcoming</option>
          </select>
          <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-ink-subtle pointer-events-none" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
        </div>
        <div class="relative">
          <select id="genre-filter" class="appearance-none bg-surface-1/60 border border-white/[0.06] text-ink-secondary text-xs font-bold pl-3.5 pr-9 py-2.5 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-red/30 cursor-pointer hover:border-white/10 hover:bg-surface-2/40 transition-all duration-200">
            <option value="">All Genres</option>
          </select>
          <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-ink-subtle pointer-events-none" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
        </div>
        <div class="flex items-center gap-2 ml-auto">
          <button id="clear-filters" class="hidden px-3.5 py-2.5 bg-surface-1/40 border border-white/[0.04] text-ink-subtle text-xs font-bold rounded-xl hover:bg-brand-red/[0.08] hover:text-brand-red hover:border-brand-red/25 transition-all duration-200">
            Clear
          </button>
          <button id="prev-page" class="px-3.5 py-2.5 bg-surface-1/60 border border-white/[0.06] text-ink-secondary text-xs font-bold rounded-xl hover:bg-surface-2/60 hover:text-ink transition-all disabled:opacity-30 disabled:cursor-not-allowed transform hover:scale-[1.03] active:scale-95 disabled:hover:scale-100" disabled>
            Prev
          </button>
          <span id="page-info" class="text-xs text-ink-muted font-medium px-1">Page 1</span>
          <button id="next-page" class="px-3.5 py-2.5 bg-surface-1/60 border border-white/[0.06] text-ink-secondary text-xs font-bold rounded-xl hover:bg-surface-2/60 hover:text-ink transition-all disabled:opacity-30 disabled:cursor-not-allowed transform hover:scale-[1.03] active:scale-95 disabled:hover:scale-100">
            Next
          </button>
        </div>
      </div>

      <div id="movies-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-x-4 gap-y-8 opacity-0 transition-opacity duration-500"></div>

      <div id="grid-skeleton" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-x-4 gap-y-8">
        {Array.from({ length: 12 }).map((_, i) => (
          <div class="space-y-3" style="animation-delay: {Math.min(i * 50, 300)}ms">
            <div class="skeleton aspect-[2/3] rounded-2xl rise-in"></div>
            <div class="space-y-2 px-1">
              <div class="skeleton h-3.5 rounded w-5/6"></div>
              <div class="skeleton h-2.5 rounded w-1/2"></div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </main>
</Layout>

<script>
  import { tmdbApi } from '../lib/api';
  import { createMediaCardElement } from '../lib/mediaCardFactory';

  let currentPage = 1;
  let totalPages = 1;

  async function loadMovies() {
    const grid = document.getElementById('movies-grid');
    const skeleton = document.getElementById('grid-skeleton');
    const prevBtn = document.getElementById('prev-page') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-page') as HTMLButtonElement;
    const pageInfo = document.getElementById('page-info');
    if (!grid || !skeleton) return;

    skeleton.style.display = '';
    grid.classList.add('opacity-0');
    grid.replaceChildren();

    const sort = (document.getElementById('sort-filter') as HTMLSelectElement)?.value || 'popular';
    const genreId = (document.getElementById('genre-filter') as HTMLSelectElement)?.value || '';

    try {
      let response;
      if (sort === 'top_rated') {
        response = await tmdbApi.topRated('movie', currentPage);
      } else if (sort === 'now_playing') {
        response = await fetch(`/api/tmdb/movie/now_playing?page=${currentPage}`).then(r => r.json());
      } else if (sort === 'upcoming') {
        response = await fetch(`/api/tmdb/movie/upcoming?page=${currentPage}`).then(r => r.json());
      } else {
        response = await tmdbApi.popular('movie', currentPage);
      }

      let movies = response?.results || [];
      totalPages = Math.min(response?.total_pages || 1, 500);

      if (genreId) {
        movies = movies.filter((m: any) => m.genre_ids?.includes(parseInt(genreId)));
      }

      const fragment = document.createDocumentFragment();
      movies.forEach((item: any) => {
        fragment.appendChild(createMediaCardElement({ ...item, media_type: 'movie' }));
      });
      grid.appendChild(fragment);

      skeleton.style.display = 'none';
      grid.classList.remove('opacity-0');

      const countEl = document.getElementById('movie-count');
      if (countEl) countEl.textContent = String(movies.length);
      if (pageInfo) pageInfo.textContent = `Page ${currentPage}`;
      prevBtn.disabled = currentPage <= 1;
      nextBtn.disabled = currentPage >= totalPages;
    } catch (e) {
      console.error('Movies load error:', e);
      skeleton.style.display = 'none';
      grid.classList.remove('opacity-0');
      grid.replaceChildren();
      grid.innerHTML = `
        <div class="col-span-full">
          <div class="surface-elevated rounded-2xl p-8 text-center border-brand-red/20 max-w-md mx-auto">
            <div class="w-14 h-14 mx-auto mb-4 rounded-2xl bg-brand-red/[0.06] border border-brand-red/20 flex items-center justify-center text-brand-red">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
              </svg>
            </div>
            <h3 class="text-base font-bold text-ink mb-1">Failed to load</h3>
            <p class="text-sm text-ink-muted">Could not fetch movie catalog.</p>
          </div>
        </div>
      `;
    }
  }

  document.addEventListener('DOMContentLoaded', async () => {
    const genreFilter = document.getElementById('genre-filter') as HTMLSelectElement;

    try {
      const res = await tmdbApi.genres('movie');
      (res.genres || []).forEach((g: any) => {
        const opt = document.createElement('option');
        opt.value = String(g.id);
        opt.textContent = g.name;
        genreFilter.appendChild(opt);
      });
    } catch {}

    loadMovies();

    document.getElementById('sort-filter')?.addEventListener('change', () => { currentPage = 1; loadMovies(); });
    document.getElementById('genre-filter')?.addEventListener('change', () => { currentPage = 1; loadMovies(); });
    document.getElementById('prev-page')?.addEventListener('click', () => { if (currentPage > 1) { currentPage--; loadMovies(); } });
    document.getElementById('next-page')?.addEventListener('click', () => { if (currentPage < totalPages) { currentPage++; loadMovies(); } });
  });
</script>
