---
import Layout from '../layouts/Layout.astro';
import MovieCard from '../components/MovieCard.svelte';

const shows = [
  { id: 1, title: 'Breaking Bad', year: '2008', poster: '/placeholder-show.jpg', rating: 9.5 },
  { id: 2, title: 'Stranger Things', year: '2016', poster: '/placeholder-show.jpg', rating: 8.7 },
];
---

<Layout title="Watchfy - TV Shows">
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-white mb-6">TV Shows</h1>
    
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
      {shows.map(show => (
        <MovieCard client:load id={show.id} title={show.title} year={show.year} poster={show.poster} rating={show.rating} type="tv" />
      ))}
    </div>
  </main>
</Layout>