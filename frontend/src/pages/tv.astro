---
import Layout from '../layouts/Layout.astro';

const shows = [
  { id: 1, title: 'Breaking Bad', year: '2008', poster: '/placeholder-show.jpg' },
  { id: 2, title: 'Stranger Things', year: '2016', poster: '/placeholder-show.jpg' },
];
---

<Layout title="Watchfy - TV Shows">
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-white mb-6">TV Shows</h1>
    
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
      {shows.map(show => (
        <a href={`/tv/${show.id}`} class="group">
          <div class="bg-zinc-800 rounded-lg overflow-hidden aspect-[2/3]">
            <img 
              src={show.poster} 
              alt={show.title}
              class="w-full h-full object-cover transition-transform group-hover:scale-105"
            />
          </div>
          <div class="mt-2">
            <h3 class="font-medium text-sm line-clamp-1">{show.title}</h3>
            <p class="text-xs text-gray-400">{show.year}</p>
          </div>
        </a>
      ))}
    </div>
  </main>
</Layout>