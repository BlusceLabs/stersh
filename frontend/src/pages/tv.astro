---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Discover TV Series | Watchfy">
  <main class="min-h-screen bg-[#09090b] text-zinc-100 pt-24 pb-20 select-none relative overflow-hidden">
    
    <div class="absolute top-0 right-1/4 w-[500px] h-[350px] bg-purple-900/5 rounded-full blur-[120px] pointer-events-none z-0"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-zinc-900 pb-5 mb-8">
        <div>
          <h1 class="text-2xl sm:text-4xl font-black text-white tracking-tighter">
            TV Series
          </h1>
          <p class="text-xs sm:text-sm text-zinc-500 font-medium mt-0.5">
            Explore trending episodic broadcasts and popular streaming series.
          </p>
        </div>
        
        <div class="flex-shrink-0 self-start sm:self-auto bg-zinc-900/60 border border-zinc-800/60 rounded-xl px-3.5 py-1.5 backdrop-blur-md">
          <span class="text-xs font-bold text-zinc-400 tracking-wide uppercase flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
            Live Catalog
          </span>
        </div>
      </div>

      <div 
        id="tv-grid" 
        class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-x-4 gap-y-8 opacity-0 transition-opacity duration-500"
      >
        </div>

      <div id="grid-skeleton" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-x-4 gap-y-8 animate-pulse">
        {Array.from({ length: 12 }).map(() => (
          <div class="space-y-3">
            <div class="aspect-[2/3] bg-zinc-900 border border-zinc-800/40 rounded-xl relative overflow-hidden">
              <div class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/5 to-transparent shimmer-wave"></div>
            </div>
            <div class="space-y-2 px-1">
              <div class="h-3.5 bg-zinc-800 rounded w-5/6"></div>
              <div class="h-2.5 bg-zinc-900 rounded w-1/2"></div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </main>
</Layout>

<script>
  import { tmdbApi } from '../lib/api';

  /**
   * Premium DOM Builder synced with unified Watchfy design tokens.
   * Compiles interactive cards explicitly routed for TV series models.
   */
  const constructTvCardElement = (show) => {
    const id = show.id;
    const title = show.name || show.original_name || 'Untitled Show';
    const year = (show.first_air_date || '').split('-')[0] || '—';
    const rating = show.vote_average || 0;
    
    const poster = show.poster_path 
      ? `https://image.tmdb.org/t/p/w500${show.poster_path}` 
      : 'https://images.unsplash.com/photo-1594909122845-11baa439b7bf?q=80&w=1470';

    const cellAnchor = document.createElement('a');
    cellAnchor.href = `/tv/${id}`;
    cellAnchor.className = "group block focus:outline-none";
    cellAnchor.setAttribute('aria-label', `View details for ${title}`);
    
    cellAnchor.innerHTML = `
      <div class="relative bg-zinc-900 rounded-xl overflow-hidden aspect-[2/3] border border-zinc-800/40 shadow-md shadow-black/40 transition-all duration-500 ease-out transform group-hover:-translate-y-1.5 group-hover:border-zinc-700/60 group-hover:shadow-xl group-hover:shadow-black/70 focus-within:ring-2 focus-within:ring-red-500/50">
        <img 
          src="${poster}" 
          alt="" 
          class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105 brightness-[0.96] group-hover:brightness-110" 
          loading="lazy" 
        />
        
        ${rating > 0 ? `
          <div class="absolute top-2 right-2 bg-zinc-950/75 backdrop-blur-md text-amber-400 font-bold text-[11px] px-2 py-1 rounded-lg flex items-center gap-1 border border-zinc-800/50 shadow-md">
            <svg class="w-3.5 h-3.5 fill-amber-400" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <span>${rating.toFixed(1)}</span>
          </div>
        ` : ''}
        
        <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-transparent to-transparent opacity-0 group-hover:opacity-40 transition-opacity duration-500 pointer-events-none"></div>
      </div>
      
      <div class="mt-2.5 px-0.5">
        <h3 class="font-semibold text-zinc-200 group-hover:text-white text-sm tracking-tight line-clamp-1 transition-colors duration-200">
          ${title}
        </h3>
        <div class="flex items-center gap-2 mt-0.5 text-[11px] font-medium text-zinc-500">
          <span>${year}</span>
          <span class="w-1 h-1 rounded-full bg-zinc-800"></span>
          <span class="uppercase font-bold tracking-wider text-[9px] text-zinc-600">Series</span>
        </div>
      </div>
    `;
    return cellAnchor;
  };

  // Lifecycle Initialization Loop Hook
  document.addEventListener('DOMContentLoaded', async () => {
    const grid = document.getElementById('tv-grid');
    const skeleton = document.getElementById('grid-skeleton');
    if (!grid || !skeleton) return;
    
    try {
      const response = await tmdbApi.popular('tv');
      const shows = response?.results || [];
      
      // Batch node appends inside a virtual memory canvas to eliminate layout thrashing
      const fragment = document.createDocumentFragment();
      shows.forEach(item => {
        fragment.appendChild(constructTvCardElement(item));
      });
      
      grid.appendChild(fragment);
      
      // Swap skeleton trackers out smoothly
      skeleton.classList.add('hidden');
      grid.classList.remove('opacity-0');
    } catch (e) {
      console.error('Watchfy TV Discovery pipeline processing exception:', e);
      skeleton.classList.add('hidden');
      grid.classList.remove('opacity-0');
      grid.innerHTML = `
        <div class="col-span-full py-16 text-center">
          <p class="text-red-400 font-bold mb-1">Catalog Sync Halted</p>
          <p class="text-zinc-500 text-xs">Failed to fetch the latest episodic releases from the provider stream.</p>
        </div>
      `;
    }
  });
</script>

<style is:global>
  @keyframes shimmer {
    100% { transform: translateX(100%); }
  }
  .shimmer-wave {
    animation: shimmer 2s infinite linear;
  }
</style>