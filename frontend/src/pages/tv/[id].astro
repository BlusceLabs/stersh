---
import Layout from '../../layouts/Layout.astro';
import EpisodeSidebar from '../../components/EpisodeSidebar.svelte';

export function getStaticPaths() {
  return [
    { params: { id: '1' } },
    { params: { id: '2' } },
    { params: { id: '3' } },
  ];
}

const { id } = Astro.params;
const seasons = [1, 2, 3];
const episodes = Array.from({ length: 10 }, (_, i) => ({ 
  number: i + 1, 
  title: `Episode ${i + 1}`, 
  duration: '45 min' 
}));
---

<Layout title="TV Show Details">
  <main class="container mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row gap-6 mb-8">
      <div class="w-64 flex-shrink-0">
        <img 
          src="/placeholder-show.jpg" 
          alt="Show poster"
          class="w-full rounded-lg"
        />
      </div>
      
      <div>
        <h1 class="text-4xl font-bold text-white mb-2">TV Show {id}</h1>
        <p class="text-gray-400 mb-4">2020 • 3 Seasons</p>
        
        <div class="flex gap-4 mb-4">
          <a href={`/watch/tv/${id}/1/1`} class="px-8 py-3 bg-yellow-500 text-black font-semibold rounded-lg hover:bg-yellow-400 transition">
            Play S1E1
          </a>
          <button class="px-6 py-3 bg-zinc-800 rounded-lg hover:bg-zinc-700 transition">
            + My List
          </button>
        </div>
        
        <p class="text-gray-300">TV show description goes here...</p>
      </div>
    </div>
    
    <section>
      <h2 class="text-2xl font-bold text-white mb-4">Episodes</h2>
      <EpisodeSidebar client:load id={parseInt(id)} seasons={seasons} episodes={episodes} />
      
      <div class="space-y-3 mt-4">
        {episodes.map(ep => (
          <a href={`/watch/tv/${id}/1/${ep.number}`} class="flex items-center gap-4 p-3 bg-zinc-800 rounded-lg hover:bg-zinc-700 transition">
            <span class="text-yellow-500 font-bold">E{ep.number}</span>
            <div>
              <h4 class="text-white font-medium">{ep.title}</h4>
              <p class="text-gray-400 text-sm">{ep.duration}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>