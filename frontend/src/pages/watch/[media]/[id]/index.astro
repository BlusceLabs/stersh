---
import Layout from '../../../layouts/Layout.astro';

const { media, id } = Astro.params;
---

<Layout title={`Watch ${media} ${id}`}>
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-white mb-6">
      Watch {media === 'movie' ? 'Movie' : 'TV Show'}
    </h1>
    
    <div class="bg-zinc-800 rounded-lg aspect-video flex items-center justify-center">
      <p class="text-gray-400">Video Player Placeholder</p>
    </div>
    
    <div class="mt-6">
      <h2 class="text-xl font-semibold text-white mb-2">Title</h2>
      <p class="text-gray-400">Description goes here...</p>
    </div>
  </main>
</Layout>