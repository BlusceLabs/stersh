---
import Layout from '../../../../layouts/Layout.astro';
import WatchUI from '../../../../components/WatchUI.svelte';

const { media, id } = Astro.params;
const { server = 'white' } = Astro.url.searchParams;

const normalizedMedia = media === 'tv' ? 'tv' : 'movie';
---

<Layout title="Watchfy">
  <main class="min-h-screen bg-[#0f0f0f] text-[#f1f1f1] antialiased pb-24">
    <WatchUI client:load media={normalizedMedia} id={id} server={server} />
  </main>
</Layout>