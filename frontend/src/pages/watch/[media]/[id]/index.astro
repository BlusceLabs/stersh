---
import Layout from '../../../../layouts/Layout.astro';
import HLSPlayer from '../../../../components/HLSPlayer.svelte';

const { media, id } = Astro.params;
const streamUrl = `/api/vidking/source?tmdbId=${id}&mediaType=${media}`;
---

<Layout title="Watch">
  <div class="min-h-screen bg-surface-sunken text-text pt-16">
    <div class="container mx-auto px-4 py-6">
      <div class="aspect-video bg-surface rounded-lg overflow-hidden mb-6">
        <HLSPlayer 
          client:load
          src={streamUrl}
          title="Watch"
          autoPlay={true}
        />
      </div>
      
      <div>
        <h1 class="text-2xl font-bold mb-2">Now Playing</h1>
        <p class="text-text-muted">Streaming from available sources</p>
      </div>
    </div>
  </div>
</Layout>