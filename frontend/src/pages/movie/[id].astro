---
// src/pages/movie/[id].astro
import Layout from '../../layouts/Layout.astro';

const { id } = Astro.params;
---

<Layout title="Loading Feature... | Watchfy">
  <main 
    id="movie-page" 
    data-movie-id={id} 
    class="min-h-screen bg-[#09090b] text-zinc-100 relative overflow-hidden"
  >
    <div id="loading-state" class="w-full h-[60vh] min-h-[400px] flex items-end p-8 md:p-16 lg:px-24 bg-gradient-to-t from-[#09090b] to-zinc-900/20 animate-pulse">
      <div class="max-w-4xl w-full flex flex-col md:flex-row gap-8 items-start">
        <div class="w-44 md:w-64 aspect-[2/3] bg-zinc-800 rounded-xl flex-shrink-0"></div>
        <div class="flex-1 space-y-4 w-full mt-4">
          <div class="h-4 bg-zinc-800 rounded w-1/4"></div>
          <div class="h-12 bg-zinc-800 rounded w-3/4"></div>
          <div class="h-20 bg-zinc-800 rounded w-full"></div>
        </div>
      </div>
    </div>

    <div id="details-target" class="opacity-0 transition-opacity duration-700 ease-out"></div>
  </main>
</Layout>

<script>
  import { tmdbApi } from '../../lib/api';

  const initMoviePage = async () => {
    const container = document.getElementById('movie-page');
    const target = document.getElementById('details-target');
    const loadingState = document.getElementById('loading-state');
    
    if (!container || !target) return;
    
    // Safely extract parameter from DOM attribute instead of context-isolated Astro object
    const movieId = container.getAttribute('data-movie-id');
    if (!movieId) return;

    try {
      const movie = await tmdbApi.details('movie', parseInt(movieId));
      
      const backdropUrl = movie.backdrop_path 
        ? `https://image.tmdb.org/t/p/original${movie.backdrop_path}` 
        : '';
        
      const posterUrl = movie.poster_path 
        ? `https://image.tmdb.org/t/p/w500${movie.poster_path}` 
        : 'https://images.unsplash.com/photo-1594909122845-11baa439b7bf?q=80&w=1470'; // High-end placeholder
        
      const year = (movie.release_date || '').split('-')[0] || '—';
      const rating = movie.vote_average || 0;
      const runtime = movie.runtime ? `${Math.floor(movie.runtime / 60)}h ${movie.runtime % 60}m` : null;
      
      // Update browser tab document title dynamically to keep SEO premium
      document.title = `${movie.title || 'Feature'} - Watchfy`;

      // Inject Premium Cinematic Document Block Architecture
      target.innerHTML = `
        ${backdropUrl ? `
          <div class="absolute top-0 left-0 right-0 h-[70vh] min-h-[500px] z-0 select-none pointer-events-none">
            <img src="${backdropUrl}" alt="" class="w-full h-full object-cover brightness-[0.35]" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#09090b] via-[#09090b]/50 to-transparent"></div>
            <div class="absolute inset-0 bg-gradient-to-r from-[#09090b] via-transparent to-transparent"></div>
          </div>
        ` : ''}

        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-[25vh] md:pt-[35vh] pb-24">
          <div class="flex flex-col md:flex-row gap-8 lg:gap-12 items-start">
            
            <div class="w-48 sm:w-64 mx-auto md:mx-0 flex-shrink-0 rounded-2xl overflow-hidden shadow-2xl shadow-black border border-zinc-800/60 transform transition-transform duration-500 hover:scale-[1.02]">
              <img src="${posterUrl}" alt="${movie.title}" class="w-full h-auto object-cover" />
            </div>
            
            <div class="flex-1 text-center md:text-left mt-4 md:mt-0">
              
              <div class="flex flex-wrap items-center justify-center md:justify-start gap-2.5 text-xs font-bold text-zinc-300 mb-4">
                <span class="bg-red-500/10 border border-red-500/30 text-red-400 px-2.5 py-1 rounded-md uppercase tracking-wide">Movie</span>
                <span class="bg-zinc-900/80 backdrop-blur-md px-2.5 py-1 rounded-md border border-zinc-800/60">${year}</span>
                ${runtime ? `<span class="bg-zinc-900/80 backdrop-blur-md px-2.5 py-1 rounded-md border border-zinc-800/60">${runtime}</span>` : ''}
                ${rating > 0 ? `
                  <span class="bg-zinc-900/80 backdrop-blur-md px-2.5 py-1 rounded-md text-amber-400 border border-zinc-800/60 flex items-center gap-1">
                    <svg class="w-3.5 h-3.5 fill-amber-400" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                    ${rating.toFixed(1)}
                  </span>
                ` : ''}
              </div>

              <h1 class="text-3xl sm:text-5xl lg:text-6xl font-black text-white tracking-tighter mb-4 leading-[1.1] drop-shadow-[0_4px_12px_rgba(0,0,0,0.6)]">
                ${movie.title}
              </h1>
              
              <div class="flex flex-wrap items-center justify-center md:justify-start gap-4 mb-8">
                <a 
                  href="/watch/movie/${movieId}" 
                  class="inline-flex items-center gap-2.5 px-8 py-3.5 bg-gradient-to-r from-red-600 to-pink-600 text-white font-bold rounded-xl hover:brightness-110 shadow-xl shadow-red-600/20 transition-all active:scale-95 group/btn"
                >
                  <svg class="w-5 h-5 fill-white transition-transform group-hover/btn:scale-110" viewBox="0 0 20 20"><path d="M6.423 4.167A1 1 0 005 5.035v9.93a1 1 0 001.423.868l8.5-4.965a1 1 0 000-1.736l-8.5-4.965z"/></svg>
                  Play Now
                </a>
                <button 
                  class="inline-flex items-center gap-2 px-6 py-3.5 bg-zinc-900/60 text-zinc-200 hover:text-white font-semibold rounded-xl border border-zinc-800/80 hover:bg-zinc-800 hover:border-zinc-700 backdrop-blur-md transition-all active:scale-95 cursor-pointer"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                  </svg>
                  My List
                </button>
              </div>

              <div class="space-y-3 max-w-3xl">
                <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-400">Synopsis</h3>
                <p class="text-zinc-300 text-sm sm:text-base leading-relaxed font-medium drop-shadow-[0_2px_4px_rgba(0,0,0,0.4)]">
                  ${movie.overview || 'No structural cinematic overview transcript has been established for this feature tracking point.'}
                </p>
              </div>

            </div>
          </div>
        </div>
      `;
      
      // Smooth reveal lifecycle swap
      loadingState?.classList.add('hidden');
      target.classList.remove('opacity-0');
    } catch (e) {
      console.error('Failed to load movie page details pipeline context:', e);
      if (loadingState) loadingState.innerHTML = `
        <div class="max-w-md mx-auto text-center py-24 px-4">
          <div class="text-red-500 font-bold mb-2">Metadata Stream Error</div>
          <p class="text-zinc-500 text-sm">Failed to successfully query records matching structural catalog identity: ${movieId}</p>
        </div>
      `;
    }
  };

  // Safe universal listener initialization regardless of cache-hydration behavior
  document.addEventListener('DOMContentLoaded', initMoviePage);
</script>