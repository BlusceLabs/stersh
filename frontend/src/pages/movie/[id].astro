---
import Layout from '../../layouts/Layout.astro';

const { id } = Astro.params;
---

<Layout title={`Movie ${id} - Watchfy`}>
  <main class="container mx-auto px-4 py-8" id="movie-page" data-movie-id={id}>
    <div class="text-center py-12">
      <p class="text-text-muted">Loading...</p>
    </div>
  </main>
</Layout>

<script>
  import { tmdbApi } from '../../lib/api';

  const id = Astro.params.id;
  
  const renderMovieDetails = (movie) => {
    const container = document.getElementById('movie-page');
    if (!container) return;
    
    const backdropUrl = movie.backdrop_path 
      ? `https://image.tmdb.org/t/p/original${movie.backdrop_path}` 
      : 'https://placehold.co/1920x1080/111111/FFFFFF?text=Backdrop';
    
    const posterUrl = movie.poster_path 
      ? `https://image.tmdb.org/t/p/w500${movie.poster_path}` 
      : 'https://placehold.co/500x750/111111/FFFFFF?text=No+Image';
    
    const year = (movie.release_date || '').split('-')[0] || '—';
    const rating = movie.vote_average || 0;
    const runtime = movie.runtime ? `${Math.floor(movie.runtime / 60)}h ${movie.runtime % 60}m` : null;
    
    container.innerHTML = `
      <div class="flex flex-col md:flex-row gap-6 mb-8">
        <div class="w-64 flex-shrink-0">
          <img src="${posterUrl}" alt="${movie.title}" class="w-full rounded-lg" />
        </div>
        
        <div>
          <h1 class="text-4xl font-bold text-text mb-2">${movie.title}</h1>
          <p class="text-text-muted mb-4"><span class="text-secondary">${year}</span> • ${runtime || '—'} • <span class="text-primary">★ ${rating.toFixed(1)}</span></p>
          
          <div class="flex gap-4 mb-4">
            <a href="/watch/movie/${id}" class="px-8 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-primary-hover transition shadow-lg shadow-primary/25">
              Play Now
            </a>
            <button class="px-6 py-3 bg-surface-raised border border-border/50 rounded-lg hover:bg-surface transition">
              + My List
            </button>
          </div>
          
          <p class="text-text-secondary mb-4">${movie.overview}</p>
        </div>
      </div>
    `;
  };

  document.addEventListener('DOMContentLoaded', async () => {
    try {
      const movie = await tmdbApi.details('movie', parseInt(id));
      renderMovieDetails(movie);
    } catch (e) {
      console.error('Failed to load movie:', e);
      const container = document.getElementById('movie-page');
      if (container) {
        container.innerHTML = '<p class="text-red-400">Failed to load movie details.</p>';
      }
    }
  });
</script>