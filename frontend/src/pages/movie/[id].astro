---
import Layout from '../../layouts/Layout.astro';
import MovieCard from '../../components/MovieCard.svelte';

export function getStaticPaths() {
  return [
    { params: { id: '1' } },
    { params: { id: '2' } },
    { params: { id: '3' } },
  ];
}

const { id } = Astro.params;
---

<Layout title="Movie Details">
  <main class="container mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row gap-6 mb-8">
      <div class="w-64 flex-shrink-0">
        <img 
          src="/placeholder-movie.jpg" 
          alt="Movie poster"
          class="w-full rounded-lg"
        />
      </div>
      
      <div>
        <h1 class="text-4xl font-bold text-white mb-2">Movie {id}</h1>
        <p class="text-gray-400 mb-4">2024 • 120 min</p>
        
        <div class="flex gap-4 mb-4">
          <a href={`/watch/movie/${id}`} class="px-8 py-3 bg-yellow-500 text-black font-semibold rounded-lg hover:bg-yellow-400 transition">
            Play Now
          </a>
          <button class="px-6 py-3 bg-zinc-800 rounded-lg hover:bg-zinc-700 transition">
            + My List
          </button>
        </div>
        
        <p class="text-gray-300">Movie description goes here...</p>
      </div>
    </div>
    
    <section class="mb-8">
      <h2 class="text-2xl font-bold text-white mb-4">More Like This</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-6 gap-4">
        {[1, 2, 3, 4, 5, 6].map(i => (
          <MovieCard client:load id={i} title={`Movie ${i}`} year="2024" />
        ))}
      </div>
    </section>
  </main>
</Layout>