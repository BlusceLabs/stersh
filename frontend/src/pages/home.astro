---
import Layout from '../layouts/Layout.astro';
import HeroCarousel from '../components/HeroCarousel.svelte';
import MediaRow from '../components/MediaRow.svelte';
import ContinueWatching from '../components/ContinueWatching.svelte';
import MyListRow from '../components/MyListRow.svelte';
import BrandLogo from '../components/BrandLogo.svelte';
---

<Layout title="Watchfy | Stream Movies & TV Series" description="Discover and stream trending movies and TV shows for free.">
  <main class="bg-surface-0 text-ink min-h-screen pb-32 lg:pb-12 relative overflow-hidden">

    <section class="w-full relative z-10">
      <HeroCarousel client:load />
    </section>

    <section class="relative z-20">
      <div class="absolute -top-32 left-0 right-0 h-96 bg-gradient-to-b from-transparent via-surface-0/95 to-surface-0 pointer-events-none z-0" aria-hidden="true"></div>

      <div class="relative z-10 max-w-content mx-auto">
        <ContinueWatching client:load />
        <MyListRow client:load />
        <MediaRow client:load title="Trending Movies" endpoint="trending/movie/week" />
        <MediaRow client:load title="Trending TV Shows" endpoint="trending/tv/week" />
        <MediaRow client:load title="Popular Movies" endpoint="movie/popular" />
        <MediaRow client:load title="Popular TV Series" endpoint="tv/popular" />
      </div>
    </section>

    <div class="absolute bottom-1/4 left-[-10%] w-[500px] h-[500px] bg-brand-red/[0.04] rounded-full blur-[150px] pointer-events-none z-0" aria-hidden="true"></div>
    <div class="absolute bottom-1/3 right-[-10%] w-[600px] h-[600px] bg-brand-purple/[0.04] rounded-full blur-[150px] pointer-events-none z-0" aria-hidden="true"></div>

  </main>
</Layout>

<script>
  fetch('/api/white/prewarm/popular?limit=5').catch(() => {});
</script>
