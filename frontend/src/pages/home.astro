---
import Layout from '../layouts/Layout.astro';
import FilterChips from '../components/FilterChips.svelte';
import ContinueWatching from '../components/ContinueWatching.svelte';
import MyListRow from '../components/MyListRow.svelte';
import InfiniteFeed from '../components/InfiniteFeed.svelte';

// Curated initial shelves — kept short on purpose.
const initialShelves = [
  { title: 'Trending now', endpoint: 'trending/movie/week', viewAllHref: '/trending' },
  { title: 'Popular on Stersh', endpoint: 'trending/tv/week', viewAllHref: '/trending' },
  { title: 'New releases', endpoint: 'movie/now_playing', viewAllHref: '/movies' },
  { title: 'Top rated', endpoint: 'movie/top_rated', viewAllHref: '/movies' },
];

// Dynamic discovery shelves — light pool so the feed stays calm.
const pool: { title: string; endpoint: string; viewAllHref?: string }[] = [
  { title: 'Sci-Fi & Fantasy',   endpoint: 'discover/movie?with_genres=878&sort_by=popularity.desc&vote_count.gte=200' },
  { title: 'Critically loved',   endpoint: 'discover/movie?vote_average.gte=7.5&vote_count.gte=500&sort_by=vote_average.desc' },
  { title: 'Hidden gems',        endpoint: 'discover/movie?vote_count.gte=20&vote_count.lte=400&vote_average.gte=7.5&sort_by=vote_average.desc' },
  { title: 'Korean dramas',      endpoint: 'discover/tv?with_genres=18&with_origin_country=KR&sort_by=popularity.desc&vote_count.gte=50' },
  { title: 'Best of the 2020s',  endpoint: 'discover/movie?primary_release_date.gte=2020-01-01&primary_release_date.lte=2029-12-31&sort_by=popularity.desc&vote_count.gte=300' },
  { title: 'Comedy',             endpoint: 'discover/movie?with_genres=35&sort_by=popularity.desc&vote_count.gte=200' },
  { title: 'Crime & thriller',   endpoint: 'discover/movie?with_genres=80&sort_by=popularity.desc&vote_count.gte=200' },
  { title: 'Documentaries',      endpoint: 'discover/movie?with_genres=99&sort_by=popularity.desc&vote_count.gte=50' },
];

const filterChips = [
  { id: 'all', label: 'All' },
  { id: 'trending', label: 'Trending' },
  { id: 'movies', label: 'Movies' },
  { id: 'tv', label: 'TV Shows' },
  { id: 'popular', label: 'Popular' },
  { id: 'top_rated', label: 'Top Rated' },
  { id: 'upcoming', label: 'Coming Soon' },
  { id: 'airing', label: 'Airing Today' },
  { id: 'new', label: 'New Releases' },
];

const chipHrefMap: Record<string, string> = {
  all: '/home',
  trending: '/trending',
  movies: '/movies',
  tv: '/tv',
  popular: '/movies?sort=popular',
  top_rated: '/movies?sort=top_rated',
  upcoming: '/movies?sort=upcoming',
  airing: '/tv?sort=airing_today',
  new: '/trending',
};
---

<Layout title="Home" description="Discover trending movies and TV shows on Stersh.">
  <main class="min-h-screen bg-base">
    <FilterChips
      chips={filterChips}
      active="all"
      hrefBuilder={(id) => chipHrefMap[id] ?? '/home'}
    />

    <div class="px-4 md:px-6 pt-2">
      <!-- Signed-out welcome state. JS removes this once it confirms a token exists. -->
      <div id="welcome-banner" class="hidden mb-6">
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 p-4 bg-base-2 border border-white/10 rounded-xl">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-yt-red flex items-center justify-center">
            <svg viewBox="0 0 24 24" class="w-5 h-5" fill="white" aria-hidden="true">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-base text-ink">Sign in to track your watch history and build a list.</p>
            <p class="text-sm text-ink-muted mt-0.5">Continue where you left off across devices.</p>
          </div>
          <div class="flex gap-2 flex-shrink-0">
            <a href="/signin" class="h-9 px-4 border border-yt-blue text-yt-blue rounded-full text-sm font-medium hover:bg-yt-blue/10 flex items-center">Sign in</a>
            <a href="/signup" class="h-9 px-4 bg-base-3 text-ink rounded-full text-sm font-medium hover:bg-base-4 flex items-center">Create account</a>
          </div>
        </div>
      </div>

      <ContinueWatching client:load />
      <MyListRow client:idle />

      <InfiniteFeed client:load initialShelves={initialShelves} pool={pool} />
    </div>
  </main>
</Layout>

<script>
  fetch('/api/white/prewarm/popular?limit=5').catch(() => {});

  // Show the welcome banner only when no auth token is present.
  // (Has to run on every page load because the page is SSR.)
  try {
    const { isAuthenticated } = await import('../lib/auth');
    if (!isAuthenticated()) document.getElementById('welcome-banner')?.classList.remove('hidden');
  } catch {}
</script>
