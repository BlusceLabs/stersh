---
import Layout from '../layouts/Layout.astro';
import HeroCarousel from '../components/HeroCarousel.svelte';
import MediaRow from '../components/MediaRow.svelte';
import ContinueWatching from '../components/ContinueWatching.svelte';
---

<Layout title="Watchfy — Stream Movies & TV Series" description="Discover and stream trending movies and TV shows for free.">
  <main class="bg-[#09090b] text-zinc-100 min-h-screen pb-24 overflow-hidden relative">
    <section class="w-full relative z-10">
      <HeroCarousel client:load />
    </section>

    <section class="relative z-20 -mt-12 md:-mt-20 lg:-mt-28 space-y-4 md:space-y-8">
      <div class="absolute -top-24 left-0 right-0 h-96 bg-gradient-to-b from-transparent via-[#09090b]/90 to-[#09090b] pointer-events-none z-0"></div>

      <div class="relative z-10">
        <ContinueWatching client:load />

        <MediaRow client:load title="Trending Movies" endpoint="trending/movie/week" />
        <MediaRow client:load title="Trending TV Shows" endpoint="trending/tv/week" />
        <MediaRow client:load title="Popular Movies" endpoint="movie/popular" />
        <MediaRow client:load title="Popular TV Series" endpoint="tv/popular" />
      </div>
    </section>

    <div class="absolute bottom-1/4 left-[-10%] w-[500px] h-[500px] bg-red-600/5 rounded-full blur-[150px] pointer-events-none z-0"></div>
    <div class="absolute bottom-1/3 right-[-10%] w-[600px] h-[600px] bg-indigo-900/5 rounded-full blur-[150px] pointer-events-none z-0"></div>
  </main>
</Layout>

<script>
  fetch('/api/white/prewarm/popular?limit=5').catch(() => {});
</script>
