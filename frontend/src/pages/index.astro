---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.svelte';
---

<Layout title="Watchfy - Home">
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold text-white mb-6">Welcome to Watchfy</h1>
    <p class="text-gray-400 text-lg mb-8">Streaming platform built with Astro, Svelte, and Qwik.</p>
    
    <div class="flex gap-4">
      <a href="/movies" class="inline-block px-6 py-3 bg-yellow-500 text-black font-semibold rounded-lg hover:bg-yellow-400 transition">
        Browse Movies
      </a>
      <Button client:load title="Svelte Button" isActive={false} />
    </div>
  </main>
</Layout>