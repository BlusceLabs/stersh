---
// src/pages/index.astro — Watchfy landing spotlight
import '@watchfy/design-tokens/styles';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en" class="h-screen w-screen overflow-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Watchfy - Stream Trending Now</title>
  </head>

  <body class="bg-surface-0 text-ink font-sans antialiased h-full w-full relative overflow-hidden">

    <!-- ===== FULL-VIEWPORT BACKDROP ===== -->
    <div class="absolute inset-0 z-0 overflow-hidden bg-black" aria-hidden="true">

      <!-- Crossfade pair: image A & B for smooth transitions -->
      <img
        id="backdrop-a"
        src={initialBackdrop}
        alt=""
        class="absolute inset-0 w-full h-full object-cover brightness-[0.22] scale-105 motion-safe:animate-[kenburns_25s_ease-out_infinite_alternate] transition-opacity duration-1000 ease-out opacity-100"
      />
      <img
        id="backdrop-b"
        src=""
        alt=""
        class="absolute inset-0 w-full h-full object-cover brightness-[0.22] scale-105 motion-safe:animate-[kenburns_25s_ease-out_infinite_alternate] transition-opacity duration-1000 ease-out opacity-0"
      />

      <!-- YouTube player -->
      <div id="video-wrapper" class="absolute inset-0 scale-[1.35] brightness-[0.25] contrast-[1.05] opacity-0 transition-opacity duration-1000 ease-out hidden">
        <div id="youtube-player" class="w-full h-full absolute top-0 left-0"></div>
      </div>

      <!-- Poster fallback (when no trailer) -->
      <div id="poster-fallback-container" class="absolute inset-0 z-20 flex items-center justify-center opacity-0 pointer-events-none transition-all duration-700 ease-out transform scale-95 hidden">
        <div class="relative group max-w-[280px] sm:max-w-[340px] rounded-2xl overflow-hidden shadow-4 border border-white/[0.06]">
          <img id="fallback-poster" src="" alt="Presentation Poster" class="w-full h-auto object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60"></div>
        </div>
      </div>

      <!-- Gradient overlays -->
      <div class="absolute inset-0 bg-gradient-to-t from-surface-0 via-transparent to-black/50 z-10 pointer-events-none"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-surface-0/90 via-surface-0/20 to-transparent z-10 pointer-events-none"></div>
      <div class="absolute inset-0 bg-radial-vignette z-10 pointer-events-none"></div>
    </div>

    <!-- ===== HERO CONTENT (full viewport) ===== -->
    <main class="relative z-30 flex flex-col h-full justify-between pointer-events-none" aria-label="Movie Spotlight">

      <!-- Top bar -->
      <header class="flex items-center justify-between p-5 sm:p-8 md:p-12 lg:p-16">
      </header>

      <!-- Bottom content -->
      <div class="pointer-events-auto pb-[env(safe-area-inset-bottom,0px)]">
        <div class="px-5 sm:px-8 md:px-12 lg:px-16 pb-8 sm:pb-12 md:pb-16 lg:pb-20 flex flex-col md:flex-row md:items-end justify-between w-full gap-8">

          <!-- Left: info -->
          <div class="max-w-2xl space-y-4 md:space-y-5">

            <!-- Logo / Title swap -->
            <div class="rise-in min-h-[48px] md:min-h-[120px] flex items-end">
              <img
                id="display-logo"
                src=""
                alt=""
                class="max-w-xs md:max-w-md lg:max-w-xl h-auto max-h-[140px] object-contain text-cinematic-lg hidden"
              />
              <h1 id="display-title" class="text-display-lg md:text-display-xl lg:text-display-2xl font-display text-ink text-cinematic-lg uppercase">
                {trendingMovies[0]?.title || 'Watchfy'}
              </h1>
            </div>

            <!-- Metadata row -->
            <div id="display-meta" class="flex flex-wrap items-center gap-2 rise-in" style="animation-delay: 80ms">
              <span id="meta-type" class="bg-brand-red/[0.12] border border-brand-red/30 text-brand-red px-2.5 py-0.5 rounded-md text-[11px] font-extrabold uppercase tracking-widest">Movie</span>
              <span id="meta-year" class="glass-strong px-2.5 py-0.5 rounded-md text-ink-secondary text-[11px] font-bold">{yearOf(trendingMovies[0])}</span>
              <span id="meta-rating" class="glass-strong px-2.5 py-0.5 rounded-md flex items-center gap-1 text-accent-warm text-[11px] font-bold">
                <svg class="w-3 h-3 fill-accent-warm" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                {ratingOf(trendingMovies[0])}
              </span>
              <span id="meta-runtime" class="hidden glass-strong px-2.5 py-0.5 rounded-md text-ink-secondary text-[11px] font-bold"></span>
            </div>

            <!-- Overview -->
            <p id="display-overview" class="text-ink-secondary text-base md:text-lg max-w-xl font-medium leading-relaxed line-clamp-3 rise-in" style="animation-delay: 160ms">
              {trendingMovies[0]?.overview || ''}
            </p>

            <!-- CTAs -->
            <div class="flex flex-wrap gap-3 sm:gap-4 items-center rise-in" style="animation-delay: 240ms">
              <a
                id="cta-play"
                href="/home"
                class="group/play px-7 sm:px-8 py-3.5 sm:py-4 bg-brand-gradient-cta text-white font-extrabold rounded-xl hover:brightness-110 transition-all duration-300 ease-exo-out transform hover:scale-[1.03] active:scale-95 shadow-3 hover:shadow-glow-red inline-flex items-center gap-2.5 text-sm uppercase tracking-wider"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" aria-hidden="true">
                  <path fill-rule="evenodd" d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z" clip-rule="evenodd" />
                </svg>
                Watch Now
              </a>

              <a
                href="/home"
                class="px-7 sm:px-8 py-3.5 sm:py-4 glass-strong text-ink font-bold rounded-xl hover:bg-white/[0.08] border border-white/[0.08] transition-all duration-300 ease-exo-out transform hover:scale-[1.03] active:scale-95 shadow-2 inline-flex items-center gap-2 text-sm uppercase tracking-wider"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                </svg>
                Home
              </a>


            </div>
          </div>

          <!-- Right: brand -->
          <div class="rise-in flex-shrink-0 md:text-right" style="animation-delay: 400ms">
            <div class="tracking-wider pointer-events-none">
              <span class="text-[10px] uppercase font-black tracking-[0.4em] text-ink-subtle block mb-1">Powered by</span>
              <h2 class="text-3xl md:text-4xl font-display font-black tracking-tighter text-brand-gradient">
                Watchfy<span class="text-ink text-xl font-normal">.</span>
              </h2>
            </div>
          </div>

        </div>
      </div>
    </main>

    <script src="https://www.youtube.com/iframe_api" async></script>
    <script is:inline define:vars={{ trendingMovies, BACKEND_URL }}>
      let currentPoolIndex = 0;
      let player = null;
      let fallbackTimerId = null;
      const pageAbort = new AbortController();

      const elWrapper = document.getElementById('video-wrapper');
      const elBackdropA = document.getElementById('backdrop-a');
      const elBackdropB = document.getElementById('backdrop-b');
      const elPosterContainer = document.getElementById('poster-fallback-container');
      const elPosterImg = document.getElementById('fallback-poster');
      const elLogo = document.getElementById('display-logo');
      const elTitle = document.getElementById('display-title');
      const elOverview = document.getElementById('display-overview');
      const elMetaYear = document.getElementById('meta-year');
      const elMetaRating = document.getElementById('meta-rating');
      const elMetaRuntime = document.getElementById('meta-runtime');
      const elCtaPlay = document.getElementById('cta-play');

      let activeBackdrop = 'a';

      window.addEventListener('pagehide', () => {
        if (fallbackTimerId) { clearTimeout(fallbackTimerId); fallbackTimerId = null; }
        pageAbort.abort();
        try { player?.stopVideo?.(); player?.destroy?.(); } catch (_) {}
      });

      function crossfadeBackdrop(src) {
        if (!src) return;
        if (activeBackdrop === 'a') {
          elBackdropB.src = src;
          elBackdropB.classList.remove('opacity-0');
          elBackdropA.classList.add('opacity-0');
          activeBackdrop = 'b';
        } else {
          elBackdropA.src = src;
          elBackdropA.classList.remove('opacity-0');
          elBackdropB.classList.add('opacity-0');
          activeBackdrop = 'a';
        }
      }

      function showVideo() {
        elPosterContainer.classList.add('hidden');
        elWrapper.classList.remove('hidden');
        void elWrapper.offsetHeight;
        elWrapper.classList.remove('opacity-0');
      }

      function showPoster() {
        elWrapper.classList.add('hidden');
        elPosterContainer.classList.remove('hidden');
        void elPosterContainer.offsetHeight;
        elPosterContainer.classList.remove('opacity-0', 'scale-95');
        elPosterContainer.classList.add('opacity-100', 'scale-100');
      }

      async function transitionMetadataContext(movie) {
        if (!movie) return;
        elOverview.textContent = movie.overview || '';

        if (movie.backdrop_path) {
          crossfadeBackdrop(`https://image.tmdb.org/t/p/original${movie.backdrop_path}`);
        }

        if (movie.poster_path) {
          elPosterImg.src = `https://image.tmdb.org/t/p/w500${movie.poster_path}`;
        }

        // Update metadata
        const year = (movie.release_date || movie.first_air_date || '').split('-')[0] || '';
        const rating = movie.vote_average ? (movie.vote_average / 2).toFixed(1) : '';
        elMetaYear.textContent = year;
        if (rating) {
          elMetaRating.innerHTML = `<svg class="w-3 h-3 fill-accent-warm" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg> ${rating}`;
          elMetaRating.classList.remove('hidden');
        } else {
          elMetaRating.classList.add('hidden');
        }
        if (movie.runtime) {
          elMetaRuntime.textContent = `${Math.floor(movie.runtime / 60)}h ${movie.runtime % 60}m`;
          elMetaRuntime.classList.remove('hidden');
        }

        // Update CTA links
        elCtaPlay.href = `/watch/movie/${movie.id}`;

        // Fetch TMDB logo
        try {
          const res = await fetch(`${BACKEND_URL}/api/tmdb/movie/${movie.id}/images?include_image_language=en,null`, { signal: pageAbort.signal });
          const data = await res.json();
          if (pageAbort.signal.aborted) return;
          const logo = data?.logos?.[0];
          if (logo) {
            elLogo.src = `https://image.tmdb.org/t/p/original${logo.file_path}`;
            elLogo.alt = movie.title || 'Movie logo';
            elLogo.classList.remove('hidden');
            elTitle.classList.add('hidden');
          } else {
            elTitle.textContent = movie.title || '';
            elTitle.classList.remove('hidden');
            elLogo.classList.add('hidden');
          }
        } catch (err) {
          if (pageAbort.signal.aborted || err?.name === 'AbortError') return;
          elTitle.textContent = movie.title || '';
          elTitle.classList.remove('hidden');
          elLogo.classList.add('hidden');
        }
      }

      async function resolveVideoSourceKey(movieId) {
        try {
          const res = await fetch(`${BACKEND_URL}/api/tmdb/movie/${movieId}/videos?language=en-US`, { signal: pageAbort.signal });
          const data = await res.json();
          if (pageAbort.signal.aborted) return null;
          const source = data.results?.find(v => v.site === 'YouTube' && (v.type === 'Trailer' || v.type === 'Teaser'));
          return source ? source.key : null;
        } catch (e) {
          if (pageAbort.signal.aborted || e?.name === 'AbortError') return null;
          return null;
        }
      }

      async function startSpotlight() {
        if (!trendingMovies || trendingMovies.length === 0) return;

        const initialMovie = trendingMovies[0];
        await transitionMetadataContext(initialMovie);
        const firstKey = await resolveVideoSourceKey(initialMovie.id);

        if (!firstKey) {
          showPoster();
          fallbackTimerId = setTimeout(advanceToNextSpotlight, 7000);
          return;
        }

        player = new YT.Player('youtube-player', {
          videoId: firstKey,
          playerVars: { autoplay: 1, mute: 1, controls: 0, showinfo: 0, rel: 0, iv_load_policy: 3, playsinline: 1, enablejsapi: 1, disablekb: 1 },
          events: {
            onReady: (event) => { event.target.mute(); event.target.playVideo(); },
            onStateChange: (event) => {
              if (event.data === 1) showVideo();
              if (event.data === 0 || event.data === 2) advanceToNextSpotlight();
            },
            onError: () => advanceToNextSpotlight()
          }
        });
      }

      function initSpotlight() {
        if (window.YT && window.YT.Player) {
          startSpotlight();
        }
      }

      async function advanceToNextSpotlight() {
        if (fallbackTimerId) { clearTimeout(fallbackTimerId); fallbackTimerId = null; }

        currentPoolIndex = (currentPoolIndex + 1) % Math.min(trendingMovies.length, 20);
        const nextMovie = trendingMovies[currentPoolIndex];

        elWrapper.classList.add('opacity-0');
        elPosterContainer.classList.add('opacity-0', 'scale-95');

        const videoKey = await resolveVideoSourceKey(nextMovie.id);
        await transitionMetadataContext(nextMovie);

        if (videoKey) {
          if (player && typeof player.loadVideoById === 'function') {
            showVideo();
            player.loadVideoById({ videoId: videoKey, startSeconds: 0, suggestedQuality: 'hd1080' });
          } else {
            showVideo();
            player = new YT.Player('youtube-player', {
              videoId: videoKey,
              playerVars: { autoplay: 1, mute: 1, controls: 0, showinfo: 0, rel: 0, iv_load_policy: 3, playsinline: 1, enablejsapi: 1, disablekb: 1 },
              events: {
                onReady: (event) => { event.target.mute(); event.target.playVideo(); },
                onStateChange: (event) => {
                  if (event.data === 1) showVideo();
                  if (event.data === 0 || event.data === 2) advanceToNextSpotlight();
                },
                onError: () => advanceToNextSpotlight()
              }
            });
          }
        } else {
          showPoster();
          fallbackTimerId = setTimeout(advanceToNextSpotlight, 7000);
        }
      }

      window.onYouTubeIframeAPIReady = function() {
        initSpotlight();
      };

      // Poll for YT readiness with 10s timeout
      let ytPollAttempts = 0;
      const ytCheckInterval = setInterval(() => {
        ytPollAttempts++;
        if (window.YT && window.YT.Player) {
          clearInterval(ytCheckInterval);
          initSpotlight();
        } else if (ytPollAttempts >= 100) {
          clearInterval(ytCheckInterval);
        }
      }, 100);
    </script>

    <style is:global>
      @keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .rise-in {
        animation: slideUp 800ms cubic-bezier(0.16, 1, 0.3, 1) both;
      }
    </style>
  </body>
</html>
