---
import Layout from '../layouts/Layout.astro';
import MovieCard from '../components/MovieCard.svelte';

const trending = [
  { id: 1, title: 'Dune', year: '2021', poster: '/placeholder-movie.jpg', rating: 8.0 },
  { id: 2, title: 'Everything Everywhere', year: '2022', poster: '/placeholder-movie.jpg', rating: 7.8 },
  { id: 3, title: 'Top Gun', year: '2022', poster: '/placeholder-movie.jpg', rating: 7.9 },
];

const popular = [
  { id: 4, title: 'Avatar', year: '2009', poster: '/placeholder-movie.jpg', rating: 7.9 },
  { id: 5, title: 'Avengers', year: '2012', poster: '/placeholder-movie.jpg', rating: 8.0 },
];
---

<Layout title="Watchfy - Home">
  <main class="container mx-auto px-4 py-8">
    <section class="mb-12">
      <h1 class="text-4xl font-bold text-white mb-2">Welcome to Watchfy</h1>
      <p class="text-gray-400 text-lg mb-6">Streaming platform built with Astro, Svelte, and Qwik.</p>
      
      <a href="/movies" class="inline-block px-6 py-3 bg-yellow-500 text-black font-semibold rounded-lg hover:bg-yellow-400 transition">
        Browse Movies
      </a>
    </section>
    
    <section class="mb-8">
      <h2 class="text-2xl font-bold text-white mb-4">Trending Now</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
        {trending.map(item => (
          <MovieCard client:load id={item.id} title={item.title} year={item.year} poster={item.poster} rating={item.rating} />
        ))}
      </div>
    </section>
    
    <section>
      <h2 class="text-2xl font-bold text-white mb-4">Popular</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
        {popular.map(item => (
          <MovieCard client:load id={item.id} title={item.title} year={item.year} poster={item.poster} rating={item.rating} />
        ))}
      </div>
    </section>
  </main>
</Layout>