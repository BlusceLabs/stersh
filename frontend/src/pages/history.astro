---
import Layout from '../layouts/Layout.astro';
import FilterChips from '../components/FilterChips.svelte';
---

<Layout title="Watch History | Watchfy">
  <main class="min-h-screen bg-base">
    <div class="px-4 md:px-6 pt-2">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-3">
          <h1 class="text-2xl font-bold text-ink">Watch history</h1>
          <span class="text-sm text-ink-muted"><span id="history-count">0</span> items</span>
        </div>
        <button id="clear-history" class="hidden text-sm text-ink-secondary hover:text-ink">Clear all watch history</button>
      </div>

      <div id="filter-bar" class="mb-6">
        <FilterChips
          chips={[
            { id: 'all', label: 'All' },
            { id: 'movies', label: 'Movies' },
            { id: 'tv', label: 'TV Shows' },
          ]}
          active="all"
          hrefBuilder={(id) => '#'}
        />
      </div>

      <div id="history-list" class="flex flex-col gap-2 opacity-0 transition-opacity duration-300"></div>

      <div id="list-skeleton" class="flex flex-col gap-2">
        {Array.from({ length: 6 }).map(() => (
          <div class="flex items-center gap-4 p-2">
            <div class="skeleton w-40 aspect-video rounded-xl flex-shrink-0"></div>
            <div class="flex-1 space-y-2 py-1">
              <div class="skeleton h-4 rounded w-2/3"></div>
              <div class="skeleton h-3 rounded w-1/3"></div>
              <div class="skeleton h-2 rounded w-1/2"></div>
            </div>
          </div>
        ))}
      </div>

      <div id="empty-state" class="hidden py-20 text-center">
        <div class="w-16 h-16 rounded-full bg-base-2 mx-auto mb-4 flex items-center justify-center text-ink-muted">
          <svg viewBox="0 0 24 24" class="w-7 h-7" fill="currentColor" aria-hidden="true">
            <path d="M12 8v4l3 3 .7-.7-2.7-2.7V8H12zm0-6a10 10 0 1 0 10 10h-2a8 8 0 1 1-8-8V2z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-ink mb-2">No watch history</h3>
        <p class="text-sm text-ink-muted mb-6">Videos you watch will show up here.</p>
        <a href="/home" class="inline-flex items-center gap-2 h-9 px-5 border border-yt-blue text-yt-blue rounded-full text-sm font-medium hover:bg-yt-blue/10">
          Browse videos
        </a>
      </div>

      <div id="auth-required" class="hidden py-20 text-center">
        <div class="w-16 h-16 rounded-full bg-base-2 mx-auto mb-4 flex items-center justify-center text-ink-muted">
          <svg viewBox="0 0 24 24" class="w-7 h-7" fill="currentColor" aria-hidden="true">
            <path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm0 2c-3.3 0-8 1.7-8 5v1h16v-1c0-3.3-4.7-5-8-5z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-ink mb-2">Sign in to view your history</h3>
        <p class="text-sm text-ink-muted mb-6">Your watch history syncs across devices.</p>
        <a href="/signin" class="inline-flex items-center gap-2 h-9 px-5 border border-yt-blue text-yt-blue rounded-full text-sm font-medium hover:bg-yt-blue/10">
          Sign in
        </a>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { tmdbApi } from '../lib/api';
  import { getToken, authFetch } from '../lib/auth';

  type FilterType = 'all' | 'movies' | 'tv';
  let currentFilter: FilterType = 'all';
  let historyData: { movies: any[]; tv_shows: any[] } = { movies: [], tv_shows: [] };

  function getAuthToken(): string | null {
    return getToken();
  }

  function setActiveChip() {
    const idx = ['all', 'movies', 'tv'].indexOf(currentFilter);
    document.querySelectorAll('#filter-bar [data-active]').forEach((el, i) => {
      el.setAttribute('data-active', i === idx ? 'true' : 'false');
    });
  }

  function getAllItems() {
    const items: any[] = [];
    historyData.movies.forEach(m => items.push({ ...m, media_type: 'movie' }));
    historyData.tv_shows.forEach(t => items.push({ ...t, media_type: 'tv' }));
    return items;
  }

  function getFilteredItems() {
    const all = getAllItems();
    if (currentFilter === 'movies') return all.filter(i => i.media_type === 'movie');
    if (currentFilter === 'tv') return all.filter(i => i.media_type === 'tv');
    return all;
  }

  function formatDate(dateStr: string): string {
    if (!dateStr) return '';
    const date = new Date(dateStr);
    const now = new Date();
    const diffMs = now.getTime() - date.getTime();
    const diffMins = Math.floor(diffMs / 60000);
    const diffHours = Math.floor(diffMs / 3600000);
    const diffDays = Math.floor(diffMs / 86400000);
    if (diffMins < 1) return 'Just now';
    if (diffMins < 60) return `${diffMins}m ago`;
    if (diffHours < 24) return `${diffHours}h ago`;
    if (diffDays < 7) return `${diffDays}d ago`;
    return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  function formatTime(seconds: number): string {
    if (!seconds) return '0:00';
    const h = Math.floor(seconds / 3600);
    const m = Math.floor((seconds % 3600) / 60);
    const s = Math.floor(seconds % 60);
    if (h > 0) return `${h}:${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
    return `${m}:${s.toString().padStart(2, '0')}`;
  }

  function tmdbImg(path: string): string {
    return path ? `https://image.tmdb.org/t/p/w300${path}` : '';
  }

  function renderList() {
    const list = document.getElementById('history-list');
    const skeleton = document.getElementById('list-skeleton');
    const emptyState = document.getElementById('empty-state');
    const countEl = document.getElementById('history-count');
    const clearBtn = document.getElementById('clear-history');

    if (!list || !skeleton || !emptyState) return;

    skeleton.style.display = 'none';
    list.classList.add('opacity-0');
    list.replaceChildren();

    const items = getFilteredItems();
    if (countEl) countEl.textContent = String(items.length);
    if (clearBtn) clearBtn.classList.toggle('hidden', items.length === 0);

    if (items.length === 0) {
      list.classList.add('hidden');
      emptyState.classList.remove('hidden');
      return;
    }

    emptyState.classList.add('hidden');
    list.classList.remove('hidden');

    items.forEach((item: any) => {
      const href = item.media_type === 'tv' && item.season && item.episode
        ? `/watch/${item.media_type}/${item.tmdb_id}?season=${item.season}&episode=${item.episode}`
        : `/watch/${item.media_type}/${item.tmdb_id}`;

      const title = item.title || item.name || 'Untitled';
      const year = (item.release_date || item.first_air_date || '').split('-')[0];
      const progressPct = Math.min(item.progress_pct || 0, 100);
      const thumb = item.backdrop_path || item.poster_path;

      const row = document.createElement('a');
      row.href = href;
      row.className = 'flex items-start gap-4 p-2 rounded-xl hover:bg-base-2 transition-colors duration-100';

      const thumbWrap = document.createElement('div');
      thumbWrap.className = 'flex-shrink-0 w-40 sm:w-44 aspect-video rounded-xl overflow-hidden bg-base-2 relative';
      if (thumb) {
        const img = document.createElement('img');
        img.src = tmdbImg(thumb);
        img.alt = title;
        img.className = 'w-full h-full object-cover';
        img.loading = 'lazy';
        thumbWrap.appendChild(img);
      }
      if (progressPct > 0) {
        const barWrap = document.createElement('div');
        barWrap.className = 'absolute bottom-0 left-0 right-0 h-1 bg-white/30';
        const bar = document.createElement('div');
        bar.className = 'h-full bg-yt-red';
        bar.style.width = `${progressPct}%`;
        barWrap.appendChild(bar);
        thumbWrap.appendChild(barWrap);
      }
      row.appendChild(thumbWrap);

      const info = document.createElement('div');
      info.className = 'flex-1 min-w-0 py-1';

      const titleEl = document.createElement('h3');
      titleEl.className = 'text-base font-medium text-ink leading-snug line-clamp-2';
      titleEl.textContent = title;
      info.appendChild(titleEl);

      const meta = document.createElement('div');
      meta.className = 'mt-1 text-sm text-ink-secondary truncate';
      const channel = item.production_companies?.[0]?.name || (item.media_type === 'tv' ? 'Series' : 'Movie');
      const parts: string[] = [];
      parts.push(channel);
      if (year) parts.push(year);
      if (item.season && item.episode) parts.push(`S${item.season}:E${item.episode}`);
      meta.textContent = parts.join(' · ');
      info.appendChild(meta);

      const progress = document.createElement('div');
      progress.className = 'mt-2 text-sm text-ink-muted';
      progress.textContent = formatTime(item.current_time) + ' / ' + formatTime(item.duration) + ' watched · ' + formatDate(item.updated_at);
      info.appendChild(progress);

      row.appendChild(info);
      list.appendChild(row);
    });

    requestAnimationFrame(() => list.classList.remove('opacity-0'));
  }

  async function fetchHistory() {
    const token = getAuthToken();
    const authRequired = document.getElementById('auth-required');
    const skeleton = document.getElementById('list-skeleton');

    if (!token) {
      if (skeleton) skeleton.style.display = 'none';
      if (authRequired) authRequired.classList.remove('hidden');
      return;
    }

    try {
      const response = await authFetch('/user/history');
      if (!response.ok) throw new Error('Failed to fetch history');
      const data = await response.json();
      historyData = { movies: data.movies || [], tv_shows: data.tv_shows || [] };

      const allItems = getAllItems();
      const enrichedItems = await Promise.all(
        allItems.map(async (item) => {
          try {
            const details = await tmdbApi.details(item.media_type, item.tmdb_id);
            return { ...item, ...details };
          } catch { return item; }
        })
      );
      historyData.movies = enrichedItems.filter(i => i.media_type === 'movie');
      historyData.tv_shows = enrichedItems.filter(i => i.media_type === 'tv');
      renderList();
    } catch (e) {
      console.error('History fetch error:', e);
      if (skeleton) skeleton.style.display = 'none';
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    fetchHistory();
    document.querySelectorAll('#filter-bar [data-active]').forEach((el, i) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        currentFilter = ['all', 'movies', 'tv'][i] as FilterType;
        setActiveChip();
        renderList();
      });
    });
  });
</script>
