---
// src/components/SimpleLayout.astro
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ['"Plus Jakarta Sans"', 'sans-serif'],
            }
          }
        }
      }
    </script>
  </head>
  <body class="bg-[#09090b] text-zinc-100 min-h-screen antialiased flex flex-col font-sans">

    <nav class="fixed top-0 left-0 right-0 h-16 z-50 bg-[#09090b]/60 backdrop-blur-md border-b border-zinc-800/40 flex items-center transition-all duration-300 select-none">
      <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between">
        
        <a href="/" class="focus:outline-none group">
          <span class="text-2xl font-black tracking-tighter bg-gradient-to-r from-red-500 via-pink-500 to-indigo-500 bg-clip-text text-transparent group-hover:opacity-90 transition duration-200">
            Watchfy<span class="text-white text-lg font-normal">.</span>
          </span>
        </a>
        
        <div class="flex items-center gap-1 text-sm font-semibold">
          <a href="/movies" class="px-3 py-1.5 rounded-full text-zinc-400 hover:text-white hover:bg-zinc-800/40 transition-all duration-200">Movies</a>
          <a href="/tv" class="px-3 py-1.5 rounded-full text-zinc-400 hover:text-white hover:bg-zinc-800/40 transition-all duration-200">TV Shows</a>
          <a href="/search" class="px-3 py-1.5 rounded-full text-zinc-400 hover:text-white hover:bg-zinc-800/40 transition-all duration-200 flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 text-zinc-500 group-hover:text-white transition-colors">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.604 10.604Z" />
            </svg>
            Search
          </a>
        </div>

      </div>
    </nav>

    <main class="flex-1 pt-16 relative w-full">
      <div class="absolute top-0 right-1/4 w-[400px] h-[400px] bg-purple-600/5 rounded-full blur-[100px] pointer-events-none z-0"></div>
      
      <div class="relative z-10">
        <slot />
      </div>
    </main>

  </body>
</html>